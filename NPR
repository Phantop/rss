      <description>&lt;div id="storytext" class="storytext storylocation linkLocation"&gt;       &lt;div id="resg-s1-37379" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 6000;         --source-height: 4000;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1100/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F54%2F6a%2Fda9047c04f86a9ee5cd1243016ae%2Fap24343376684573.jpg" class="img" type="image/webp" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F54%2F6a%2Fda9047c04f86a9ee5cd1243016ae%2Fap24343376684573.jpg" data-format="webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1100/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F54%2F6a%2Fda9047c04f86a9ee5cd1243016ae%2Fap24343376684573.jpg" class="img" type="image/jpeg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F54%2F6a%2Fda9047c04f86a9ee5cd1243016ae%2Fap24343376684573.jpg" data-format="jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1100/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F54%2F6a%2Fda9047c04f86a9ee5cd1243016ae%2Fap24343376684573.jpg" class="img" alt="A man walks by a broken portrait of the late Syrian President Hafez Assad as people search for belongings in the ransacked private residence of Syrian President Bashar Assad in the Malkeh district of Damascus, Syria, on Sunday." data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F54%2F6a%2Fda9047c04f86a9ee5cd1243016ae%2Fap24343376684573.jpg" data-format="jpeg" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 A man walks by a broken portrait of the late Syrian President Hafez Assad as people search for belongings in the ransacked private residence of Syrian President Bashar Assad in the Malkeh district of Damascus, Syria, on Sunday.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Hussein Malla/AP                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;Bashar al-Assad's residence in Damascus was ransacked Sunday after rebels seized control of the Syrian capital, forcing the deposed president to flee the country.&lt;/p&gt;   &lt;div id="resnx-s1-5221639-100" class="bucketwrap internallink insettwocolumn inset2col"&gt;                     &lt;!-- END CLASS="BUCKET IMG" --&gt;    &lt;/div&gt;     &lt;!-- END ID="RESNX-S1-5221639-100" CLASS="BUCKETWRAP INTERNALLINK INSETTWOCOLUMN INSET2COL " --&gt;    &lt;p&gt;Photos from the Associated Press show Assad's residence in shambles, with empty cabinets and books, paintings and other personal belongings scattered across the floors. In one image, a man is seen attempting to take a lamp while others canvas the room. In another, a group of people pose with smiles and peace signs where Assad once lived.&lt;/p&gt;   &lt;div id="resg-s1-37380" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 6000;         --source-height: 4000;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1d%2F9b%2Fa42ace18401d942656014fa7de58%2Fap24343380873603-1.jpg" class="img" alt="A man tries to take a lamp as people search for belongings in the ransacked private residence of Syrian President Bashar Assad in the Malkeh district of Damascus, Syria, on Sunday." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 A man tries to take a lamp as people search for belongings in the ransacked private residence of Syrian President Bashar Assad in the Malkeh district of Damascus, Syria, on Sunday.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Hussein Malla/AP                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;The reactions from Syrians since Assad's downfall reflect the deep animosity that he engendered within the country. For more than 50 years, &lt;a href="https://www.npr.org/2024/12/08/g-s1-37298/in-syria-the-assads-leave-a-bitter-legacy-after-a-half-century-of-repressive-rule"&gt;the Assad family ruled with an iron grip&lt;/a&gt; and frequently deployed Syria's feared security forces to crush dissent. &lt;/p&gt;       &lt;p&gt;Assad, who took power in 2000 following the death of his father, was known for his violent crackdowns on opposition over more than a decade of civil war in Syria. The U.S. and the United Nations have both blamed Assad for a chemical weapons attack that killed hundreds — and perhaps more than 1,000 people — in 2013. An international arrest warrant &lt;a href="https://apnews.com/article/syria-france-assad-war-crimes-arrest-warrant-d64d25b39801dafdcbe031558b52b81b"&gt;was issued&lt;/a&gt; against Assad last year after France's top court accused him of complicity in war crimes during the civil war. &lt;/p&gt;   &lt;div id="resg-s1-37385" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 6000;         --source-height: 4000;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x4000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F82%2F07%2F9c626d5b43618db17a74533bd4f0%2Fap24343517017935.jpg" class="img" alt="A group of people take a family photo while sitting on a couch in a hall of Syrian President Bashar Assad&amp;#039;s presidential palace in Damascus, Syria, Sunday." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 A group of people take a family photo while sitting on a couch in a hall of Syrian President Bashar Assad's presidential palace in Damascus, Syria, Sunday.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Hussein Malla/AP                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;Within hours of rebels entering the Syrian capital, Assad landed in Russia, where according the country's state-run news agency Tass, he was granted asylum. &lt;/p&gt;   &lt;div id="resg-s1-37382" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 8640;         --source-height: 5760;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8640x5760+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc7%2Fd8%2Faa54072548a4ac5bde3cc9e73d4b%2Fap24343398355940.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8640x5760+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc7%2Fd8%2Faa54072548a4ac5bde3cc9e73d4b%2Fap24343398355940.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8640x5760+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc7%2Fd8%2Faa54072548a4ac5bde3cc9e73d4b%2Fap24343398355940.jpg 800w, h