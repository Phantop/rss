%2F9d%2Fe6b316a94b42bbffd5474ef5fc56%2F20250219-dsc0210-edit.jpg" sizes="(min-width: 1300px) 1238px, (min-width: 1025px) calc(100vw - 60px), (min-width: 768px) calc(100vw - 60px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2925x1950+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa7%2F9d%2Fe6b316a94b42bbffd5474ef5fc56%2F20250219-dsc0210-edit.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2925x1950+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa7%2F9d%2Fe6b316a94b42bbffd5474ef5fc56%2F20250219-dsc0210-edit.jpg" class="img" alt="Lohinov uses a flashlight just to walk from one building to another at night in the fire station." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Lohinov uses a flashlight just to walk from one building to another at night in the fire station.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Claire Harbage/NPR                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt; &lt;/div&gt;</description>
