3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbc%2Fcb%2F72720c944010af854d74fd8d3d55%2Fcecile-mclorin-salvant-with-every-breath.jpeg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/700x700+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbc%2Fcb%2F72720c944010af854d74fd8d3d55%2Fcecile-mclorin-salvant-with-every-breath.jpeg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/700x700+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbc%2Fcb%2F72720c944010af854d74fd8d3d55%2Fcecile-mclorin-salvant-with-every-breath.jpeg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/700x700+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbc%2Fcb%2F72720c944010af854d74fd8d3d55%2Fcecile-mclorin-salvant-with-every-breath.jpeg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/700x700+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbc%2Fcb%2F72720c944010af854d74fd8d3d55%2Fcecile-mclorin-salvant-with-every-breath.jpeg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/700x700+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbc%2Fcb%2F72720c944010af854d74fd8d3d55%2Fcecile-mclorin-salvant-with-every-breath.jpeg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/700x700+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbc%2Fcb%2F72720c944010af854d74fd8d3d55%2Fcecile-mclorin-salvant-with-every-breath.jpeg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/700x700+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbc%2Fcb%2F72720c944010af854d74fd8d3d55%2Fcecile-mclorin-salvant-with-every-breath.jpeg" class="img" alt="cecile-mclorin-salvant-with-every-breath.jpeg" loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;         &lt;/div&gt;       &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;a href="https://www.npr.org/people/140955737/ann-powers" target="_blank"&gt;&lt;em&gt;Ann Powers&lt;/em&gt;&lt;/a&gt;&lt;em&gt; recommends:&lt;/em&gt; &lt;br&gt;&lt;strong&gt;Cécile McLorin Salvant, &lt;em&gt;With Every Breath I Take&lt;/em&gt;&lt;/strong&gt;&lt;/p&gt;   &lt;p&gt;Working with arranger Darcy James Argue and the Netherlands' Metropole Orkest, Cécile McLorin Salvant — jazz's most brilliant living vocalist — rebuilds the genre's repertoire from the inside out. Go deeper, and you'll find the thread. Each song animates a soul in transition: falling in or out of love, leaving or being left, giving up something crucial, finding what makes life bearable in pain's aftermath. Salvant's soliloquies travel across time; her "Sophisticated Lady" considers both Ella and Billie while drawing its own conclusions about the costs of the good life. Yet even as she displays deep insight into Ellington, Brecht, Legrand and Coward, Salvant always keeps the listener in the present, deep within the changes the selves in these songs express. Her mission is to reveal new ways to think about what Sondheim distilled in one song she owns here: being alive.&lt;/p&gt;   &lt;ul class="edTag rte2-style-ul"&gt;&lt;li&gt;&lt;a href="https://www.npr.org/2018/09/24/651120530/c-cile-mclorin-salvant-tiny-desk-concert" target="_blank"&gt;Watch Cécile McLorin Salvant's Tiny Desk Concert&lt;/a&gt;&lt;/li&gt;&lt;/ul&gt;   &lt;div class="hr"&gt;&lt;hr /&gt;&lt;/div&gt;       &lt;div id="resg-s1-131169" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source