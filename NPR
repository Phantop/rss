    <item>
      <title>Shot in secret, 'The Seed of the Sacred Fig' calls out Iran's authoritarian regime</title>
      <author>Justin Chang</author>
      <link>https://www.npr.org/2024/12/11/nx-s1-5223531/the-seed-of-the-sacred-fig-review-iran</link>
      <comments>https://text.npr.org/2024/12/11/nx-s1-5223531/the-seed-of-the-sacred-fig-review-iran</comments>
      <guid isPermaLink="true">https://www.npr.org/2024/12/11/nx-s1-5223531/the-seed-of-the-sacred-fig-review-iran</guid>
