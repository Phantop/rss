    <item>
      <title>Think you can't dance? Get up and try these tips in our comic. We dare you!</title>
      <author>Connie Hanzhang Jin</author>
      <link>https://www.npr.org/2024/12/19/nx-s1-5232811/think-you-cant-dance-get-up-and-try-these-tips-in-our-comic-we-dare-you</link>
      <comments>https://text.npr.org/2024/12/19/nx-s1-5232811/think-you-cant-dance-get-up-and-try-these-tips-in-our-comic-we-dare-you</comments>
      <guid isPermaLink="true">https://www.npr.org/2024/12/19/nx-s1-5232811/think-you-cant-dance-get-up-and-try-these-tips-in-our-comic-we-dare-you</guid>
