      <description>&lt;div id="storytext" class="storytext storylocation linkLocation"&gt;       &lt;div id="resg-s1-50819" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 3000;         --source-height: 1698;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1698+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fba%2Fa0%2F8778cf2742288e8d55e8480e7967%2Fai-generated-trump-gaza.jpg" class="img" alt="A composite made from an AI-generated video President Trump posted to social media on Tuesday night." fetchpriority="high" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 A composite made from an AI-generated video President Trump posted to social media on Tuesday night.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Screenshots via Instagram. Annotation by NPR                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;Arabs and Muslims in the United States and abroad are criticizing a controversial video posted by President Trump on social media.&lt;/p&gt;   &lt;p&gt;The apparently AI-generated video includes depictions of Trump and Israeli Prime Minister Benjamin Netanyahu sunbathing in Gaza, and imagines scenes of destruction in Gaza transformed into a glitzy Riviera-style resort called "TRUMP GAZA."&lt;/p&gt;   &lt;div id="resnx-s1-5309695-100" class="bucketwrap statichtml"&gt;             &lt;iframe src="https://truthsocial.com/@realDonaldTrump/114068387897265338/embed" class="truthsocial-embed truthsocial-video" style="max-width: 100%; border: 0" width="600" allowfullscreen="allowfullscreen"&gt;&lt;/iframe&gt;&lt;script src="https://truthsocial.com/embed.js" async="async"&gt;&lt;/script&gt;    &lt;/div&gt;     &lt;!-- END ID="RESNX-S1-5309695-100" CLASS="BUCKETWRAP STATICHTML" --&gt;    &lt;p&gt;The video also shows children running out of the rubble into a world of palm trees and luxury buildings, and a towering golden statue of Trump. It depicts men in apparent drag dancing in bikinis on the beach, Trump enjoying a belly dancer and a man resembling Elon Musk being showered with cash in the form of U.S. currency.&lt;/p&gt;   &lt;p&gt;The post comes weeks after Trump suggested the U.S. should take over the Gaza strip and relocate Palestinians.&lt;/p&gt;   &lt;div id="resnx-s1-5309695-101" class="bucketwrap internallink insettwocolumn inset2col"&gt;                     &lt;!-- END CLASS="BUCKET IMG" --&gt;    &lt;/div&gt;     &lt;!-- END ID="RESNX-S1-5309695-101" CLASS="BUCKETWRAP INTERNALLINK INSETTWOCOLUMN INSET2COL " --&gt;    &lt;p&gt;In Gaza, many residents have little to no internet service, but some who viewed the video expressed anger to NPR Gaza producer Anas Baba. Baba showed the video to 20-year-old Mohamed Abdelrahman who rejected the idea.&lt;/p&gt;   &lt;p&gt;"We won't be lured by a few statues and money, leave us alone and let us rebuild our homes by ourselves," he told Baba.&lt;/p&gt;   &lt;div id="resnx-s1-5309695-102" class="bucketwrap internallink insettwocolumn inset2col"&gt;                     &lt;!-- END CLASS="BUCKET IMG" --&gt;    &lt;/div&gt;     &lt;!-- END ID="RESNX-S1-5309695-102" CLASS="BUCKETWRAP INTERNALLINK INSETTWOCOLUMN INSET2COL " --&gt;    &lt;p&gt;Faye Nemer, CEO and Founder of the MENA (Middle East and North Africa) American Chamber of Commerce in Dearborn, Michigan, called the video "offensive and counterproductive to peace talks" in a statement to NPR.&lt;/p&gt;   &lt;p&gt;Nemer, who says she voted for Trump in November, is calling on him to remove the video and issue a "reconciliatory statement."&lt;/p&gt;    &lt;/div&gt;</description>
