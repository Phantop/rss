Fgettyimages-2219731254.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3200x2133+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F80%2Fbb%2F8b66441848b1858ae79493b3b6ee%2Fgettyimages-2219731254.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3200x2133+0+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F80%2Fbb%2F8b66441848b1858ae79493b3b6ee%2Fgettyimages-2219731254.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3200x2133+0+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F80%2Fbb%2F8b66441848b1858ae79493b3b6ee%2Fgettyimages-2219731254.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3200x2133+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F80%2Fbb%2F8b66441848b1858ae79493b3b6ee%2Fgettyimages-2219731254.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3200x2133+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F80%2Fbb%2F8b66441848b1858ae79493b3b6ee%2Fgettyimages-2219731254.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3200x2133+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F80%2Fbb%2F8b66441848b1858ae79493b3b6ee%2Fgettyimages-2219731254.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3200x2133+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F80%2Fbb%2F8b66441848b1858ae79493b3b6ee%2Fgettyimages-2219731254.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3200x2133+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F80%2Fbb%2F8b66441848b1858ae79493b3b6ee%2Fgettyimages-2219731254.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3200x2133+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F80%2Fbb%2F8b66441848b1858ae79493b3b6ee%2Fgettyimages-2219731254.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3200x2133+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F80%2Fbb%2F8b66441848b1858ae79493b3b6ee%2Fgettyimages-2219731254.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3200x2133+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F80%2Fbb%2F8b66441848b1858ae79493b3b6ee%2Fgettyimages-2219731254.jpg" class="img" alt="Smoke billows from an explosion at the Islamic Republic of Iran Broadcasting (IRIB) building in Tehran after an Israeli strike hit the building, cutting off live coverage, on June 16." fetchpriority="high" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Smoke billows from an explosion at the Islamic Republic of Iran Broadcasting (IRIB) building in Tehran after an Israeli strike hit the building, cutting off live coverage, on June 16.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          AFP/Getty Images                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;AMMAN, Jordan — Roxana, a young shop manager living alone in Tehran, was panicking during the war with Israel. Her family lives outside the Iranian capital. Her boyfriend was on an Iranian base doing compulsory military service; unreachable and potentially in danger. Even her psychotherapist had fled the bombing in Tehran. So she turned to ChatGPT.&lt;/p&gt;   &lt;div id="resnx-s1-5449064-100" class="bucketwrap internallink mediapromo primary"&gt;             &lt;h4 class="internallink__slug"&gt;World&lt;/h4&gt;       &lt;h2 class="internallink__title"&gt;Iran's leadership considers its next move&lt;/h2&gt;       &lt;article id="resnx-s1-5501718-1" class="bucketwrap resaudio" aria-label="audio-module"&gt;&lt;div class="audio-module"&gt;       &lt;h4 class="audio-module-title"&gt;Iran's leadership considers its next move&lt;/h4&gt;    &lt;div class="audio-module-controls-wrap" data-audio='{"uid":"nx-s1-5441718:nx-s1-5501718-1","available":true,"duration":223,"title":"Iran\u0027s leadership considers its next move","audioUrl":"https:\/\/ondemand.npr.org\/anon.npr-mp3\/npr\/atc\/2025\/06\/20250622_atc_iran_s_leadership_considers_its_next_move.mp3?size=3569834&amp;d=223065&amp;e=nx-s1-5441718&amp;sc=siteplayer","storyUrl":"https:\/\/www.npr.org\/2025\/06\/22\/nx-s1-5441718\/irans-leadership-considers-its-next-move","slug":"World","program":"All Things Considered","affiliation":"","song":"","artist":"","album":"","track":0,"type":"segment","subtype":"other","skipSponsorship":false,"hasAdsWizz":false,"isStreamAudioType":false}' data-audio-metrics='[]'&gt;         &lt;div class="audio-module-controls"&gt;             &lt;a class="audio-module-listen" href="https://ondemand.npr.org/anon.npr-mp3/npr/atc/2025/06/20250622_atc_iran_s_leadership_considers_its_next_move.mp3?size=3569834&amp;amp;d=223065&amp;amp;e=nx-s1-5441718&amp;amp;sc=siteplayer&amp;amp;aw_0_1st.playerid=siteplayer"&gt;                 &lt;b class="audio-module-listen-inner"&gt;                     &lt;b class="audio-mo