2F%2Fnpr-brightspot.s3.amazonaws.com%2Faf%2F70%2Fae8732874f73ac8a859944b40aad%2F1139878-1.png" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/png" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1500x800+0+0/resize/1100/quality/50/format/png/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faf%2F70%2Fae8732874f73ac8a859944b40aad%2F1139878-1.png" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1500x800+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faf%2F70%2Fae8732874f73ac8a859944b40aad%2F1139878-1.png" class="img" alt="&amp;quot;Suited to Lead: The Lives of Six Presidents Through Fashion,&amp;quot; is a virtual exhibit by the White House Historical Association featuring six presidents Theodore Roosevelt (clockwise from the far left), Jimmy Carter, George Washington, Abraham Lincoln, Harry S. Truman and John Quincy Adams." fetchpriority="high" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 "Suited to Lead: The Lives of Six Presidents Through Fashion," is a virtual exhibit by the White House Historical Association featuring  six presidents Theodore Roosevelt (clockwise from the far left), Jimmy Carter, George Washington, Abraham Lincoln, Harry S. Truman and John Quincy Adams.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          White House Historical Association                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;There's been much conversation about the fashion choices of &lt;a href="https://www.npr.org/2008/12/29/98610324/like-it-or-not-michelle-obama-is-now-a-style-icon" target="_blank"&gt;America's first ladies&lt;/a&gt;, from Jacqueline Kennedy to Michelle Obama. But a new exhibit unveiled this week showcases the clothing choices of the presidential men of the White House — and what those sartorial statements meant — from a Founding Father to a peanut farmer.&lt;/p&gt;   &lt;p&gt;&lt;a href="https://www.whitehousehistory.org/digital-library/exhibits/suited-to-lead-the-lives-of-six-presidents-through-fashion" target="_blank"&gt;"Suited to Lead,"&lt;/a&gt; an online exhibit by the White House Historical Association examines how presidents used their dress to make statements about themselves and their governance.&lt;/p&gt;   &lt;p&gt;It highlights the styles of George Washington, John Quincy Adams, Abraham Lincoln, Harry S. Truman, Theodore Roosevelt and Jimmy Carter.&lt;/p&gt;       &lt;div id="resg-s1-89661" class="bucketwrap image medium"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 1394;         --source-height: 2000;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/300/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 300w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 1600w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg" sizes="(min-width: 1350px) 298px, (min-width: 1025px) calc(((100vw - 365px)/3) - 30px), (min-width: 768px) calc(((100vw - 30px)/3) - 30px), calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/300/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 300w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg 1600w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg" sizes="(min-width: 1350px) 298px, (min-width: 1025px) calc(((100vw - 365px)/3) - 30px), (min-width: 768px) calc(((100vw - 30px)/3) - 30px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1394x2000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F4e%2F87%2F5471f29d4140bcbb601fca200291%2Fabraham-lincoln-1861.jpg" class="img" alt="This glass plate collodion negative, a type of photograph, is of President-elect Abraham Lincoln, taken on Feb. 24, 1861, by Alexander Gardner in the days following Lincoln’s arrival in Washington, D.C., ahead of his inauguration. He is dressed in the outfit that would become his most recognizable look: a black frock coat, matching waistcoat and trousers, a narrow black cravat, and polished black leather shoes. His hat rests on the table next to him." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 This glass plate collodion negative, a type of photograph, is of President-elect Abraham Lincoln, taken on Feb. 24, 1861, by Alexander Gardner in the days following Lincoln's arrival in Washington, D.C., ahead of his inauguration. He is dressed in the outfit that would become his most recognizable look.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Alexander Gardner/White House Historical Association                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;"The presidents were so much more interested in dress and fashion than we might typically think," said exhibit curator Fiona Hubbard, a New York University student mastering in costume studies who interned at the association.&lt;/p&gt;   &lt;p&gt;"They all had a really unique approach to how they dressed and all of them really impacted or left their own mark in dress in a way that you can see through the objects that are in the exhibit."&lt;/p&gt;   &lt;p&gt;In the days of the Revolutionary War, &lt;a href="https://www.whitehousehistory.org/digital-library/exhibits/suited-to-lead-the-lives-of-six-presidents-through-fashion/george-washington" target="_blank"&gt;George Washington&lt;/a&gt;, for example, wanted to set himself apart from the newly deposed British rule over the American colonies.&lt;/p&gt;   &lt;p&gt;"For him, that came in the form of homespun fabrics — or fabrics that were made in America with American materials, as well as by color," Hibbard said.&lt;/p&gt;   &lt;p&gt;"The British army wore red coats, and to situate themselves as opposed to British rule, George Washington commanded the Continental Army to wear blue coats," she said. "So he was dressed as a visual signal of what it meant to be American, and this did really impact society. It was all about being American, looking American, dressing American at that time."&lt;/p&gt;   &lt;div id="resg-s1-89648" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 3000;         --source-height: 2038;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/400/quality/85/format/tiff/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/600/quality/85/format/tiff/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/800/quality/85/format/tiff/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/900/quality/85/format/tiff/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/1200/quality/85/format/tiff/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/1600/quality/85/format/tiff/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/1800/quality/85/format/tiff/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/tiff" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/1100/quality/50/format/tiff/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2038+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fed%2F786933464394a0ec423fda733806%2F1139909.tif" class="img" alt="This painting by John Trumbull depicts the British surrender at Yorktown, marking the end of the Revolutionary War. The defeated British army marches between the Americans on the right, led by General George Washington, and the French on the left, led by General Jean-Baptiste Rochambeau. At the center, on horseback, Major General Benjamin Lincoln, Washington’s second-in-command, accepts the official surrender from General Lord Cornwallis’s deputy, General Charles O’Hara." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 This painting by John Trumbull depicts the British surrender at Yorktown, marking the end of the Revolutionary War. The defeated British army marches between the Americans on the right, led by General George Washington, and the French on the left, led by General Jean-Baptiste Rochambeau. At the center, on horseback, Major General Benjamin Lincoln, Washington's second-in-command, accepts the official surrender from General Lord Cornwallis's deputy, General Charles O'Hara.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          John Trumbull/White House Historical Association                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;Nearly two centuries later, &lt;a href="https://www.whitehousehistory.org/digital-library/exhibits/suited-to-lead-the-lives-of-six-presidents-through-fashion/jimmy-carter" target="_blank"&gt;Jimmy Carter&lt;/a&gt; would use his fashion to make a statement as well.&lt;/p&gt;   &lt;div id="resnx-s1-5543195-100" class="bucketwrap internallink insettwocolumn inset2col"&gt;                     &lt;!-- END CLASS="BUCKET IMG" --&gt;    &lt;/div&gt;     &lt;!-- END ID="RESNX-S1-5543195-100" CLASS="BUCKETWRAP INTERNALLINK INSETTWOCOLUMN INSET2COL " --&gt;    &lt;p&gt;"I think his fashion can tell us about society's move toward a more comfortable and casual style," Hibbard said.&lt;/p&gt;   &lt;p&gt;"When he was elected president, only a few weeks later, he was on television, and he was in the White House wearing a cardigan, and that was a huge topic of conversation," she noted.&lt;/p&gt;   &lt;p&gt;The former peanut farmer from Georgia famously showcased his love of the cozy sweaters in a &lt;a href="https://www.npr.org/2023/02/23/1158935139/as-president-jimmy-carter-focused-on-energy-conservation-at-a-time-of-long-gas-l" target="_blank"&gt;televised address&lt;/a&gt;, using a knit cardigan and a fireplace to encourage Americans to turn down their thermostats for energy conservation — a key plank of his White House agenda.&lt;/p&gt;   &lt;div id="resg-s1-89649" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 5184;         --source-height: 3456;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5184x3456+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff7%2Fd1%2Fefe7dfe74620b3083b89027dfa48%2Fap182712836495.jpg" class="img" alt="President Jimmy Carter&amp;#039;s cardigan is displayed at the Smithsonian&amp;#039;s National Museum of American History in Washington on June 16, 2015. " loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 President Jimmy Carter's cardigan is displayed at the Smithsonian's National Museum of American History in Washington on June 16, 2015.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Andrew Harnik/AP                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;"Even designers commented on it, and they were talking about how men should and can dress in American society, which was becoming more casual at the time," Hibbard said.&lt;/p&gt;       &lt;p&gt;From &lt;a href="https://www.whitehousehistory.org/digital-library/exhibits/suited-to-lead-the-lives-of-six-presidents-through-fashion/abraham-lincoln" target="_blank"&gt;Abraham Lincoln&lt;/a&gt; trading in his preferred workwear in favor for what would become his signature stovepipe hat and black frock coat — to &lt;a href="https://www.whitehousehistory.org/digital-library/exhibits/suited-to-lead-the-lives-of-six-presidents-through-fashion/theodore-roosevelt" target="_blank"&gt;Teddy Roosevelt's&lt;/a&gt; evolving fashion from his buckskin suit-wearing days on America's frontier, to the Rough Riders uniform he donned as a calvaryman, to the sharply tailored suits he wore in his presidency, Hibbard said presidential fashion has always delivered a message. &lt;/p&gt;   &lt;p&gt;"There were a lot of articles written about the way that these presidents dressed, whether neutral, or positive or negative," she said. "I found that really interesting how …   people at that time responded to what they were wearing."&lt;/p&gt;   &lt;div id="resnx-s1-5543195-101" class="bucketwrap internallink insettwocolumn inset2col"&gt;                     &lt;!-- END CLASS="BUCKET IMG" --&gt;    &lt;/div&gt;     &lt;!-- END ID="RESNX-S1-5543195-101" CLASS="BUCKETWRAP INTERNALLINK INSETTWOCOLUMN INSET2COL " --&gt;    &lt;p&gt;Summer Anne Lee, a fashion historian and adjunct professor at the Fashion Institute of Technology, said Hibbard's exhibit shows just how much personality certain presidents tended to impart in their style of dress, and how societal changes may have affected what leaders chose to wear.&lt;/p&gt;   &lt;p&gt;"We have to keep in mind that the presidency … has, up until this point, always been occupied by men and in large part by older men, and so a person in that job is expected to dress quite seriously, is expected to dress quite formally and quite traditionally," Lee said.&lt;/p&gt;   &lt;p&gt;The exhibit "highlights some moments where that's challenged," she said.&lt;/p&gt;   &lt;p&gt;Lee — whose forthcoming book &lt;em&gt;Presidential Fashion: An Illustrated History &lt;/em&gt;takes a deep dive on White House fashion takes — notes, for example, &lt;a href="https://www.whitehousehistory.org/digital-library/exhibits/suited-to-lead-the-lives-of-six-presidents-through-fashion/john-quincy-adams" target="_blank"&gt;John Quincy Adams' shift&lt;/a&gt; in the 1820s from wearing traditional knee breeches, to the more modern style of pantaloons, or long trousers.&lt;/p&gt;   &lt;p&gt;"And that was actually very controversial because everyday, average Americans had been wearing these pantaloons for quite some time — even a few decades at that point," Lee said.&lt;/p&gt;   &lt;p&gt;"But the presidency was meant to be this, almost frozen-in-time kind of George Washington-esque position," she said. "So it was controversial for him to adopt that clothing, but at the same time, it made him more relatable to everyday Americans."&lt;/p&gt;       &lt;p&gt;And as visual access to the president became more available with the invention of the camera, the need to make a statement with your clothes became more important to these commanders-in-chief.&lt;/p&gt;   &lt;div id="resg-s1-89652" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 2998;         --source-height: 2481;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2998x2481+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F3d%2F58%2F772408fb45c3a8ccd083e62bc301%2Fap671041866270.jpg" class="img" alt="Moderator Howard K. Smith sits between, Sen. John Kennedy (left) and Vice President Richard Nixon as they appear on a television studio monitor during their debate in Chicago on Sept. 26, 1960." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Moderator Howard K. Smith sits between, Sen. John Kennedy (left) and Vice President Richard Nixon as they appear on a television studio monitor during their debate in Chicago on Sept. 26, 1960.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          ‎&lt;br&gt;/AP                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;"We get so many more televised appearances ever since that 1960 debate between John F. Kennedy and Richard Nixon, where Nixon was not looking so good on camera, even if he looked OK in person," Lee said.&lt;/p&gt;   &lt;p&gt;"No presidential candidate was ever able to forget how important it was how they appeared on television. And today we have social media, so I think it's on the forefront of every candidate's mind to try to appeal to the masses and look more relatable," she said.&lt;br&gt;&lt;/p&gt; &lt;/div&gt;</description>
