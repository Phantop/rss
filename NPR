zonaws.com%2F08%2F07%2F5bd3327d4d7bb0aef33003377b1c%2Fstanding-buddha-750-850-ce-thailand-likely-from-prasat-hin-khao-plai-bat-ii-buriram-province-bronze-asian-art-museum-of-san-francisco-the-avery-brundage-collection-b65b70-photograph-asian-art-museum-6.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/900x1200+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F08%2F07%2F5bd3327d4d7bb0aef33003377b1c%2Fstanding-buddha-750-850-ce-thailand-likely-from-prasat-hin-khao-plai-bat-ii-buriram-province-bronze-asian-art-museum-of-san-francisco-the-avery-brundage-collection-b65b70-photograph-asian-art-museum-6.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/900x1200+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F08%2F07%2F5bd3327d4d7bb0aef33003377b1c%2Fstanding-buddha-750-850-ce-thailand-likely-from-prasat-hin-khao-plai-bat-ii-buriram-province-bronze-asian-art-museum-of-san-francisco-the-avery-brundage-collection-b65b70-photograph-asian-art-museum-6.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/900x1200+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F08%2F07%2F5bd3327d4d7bb0aef33003377b1c%2Fstanding-buddha-750-850-ce-thailand-likely-from-prasat-hin-khao-plai-bat-ii-buriram-province-bronze-asian-art-museum-of-san-francisco-the-avery-brundage-collection-b65b70-photograph-asian-art-museum-6.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/900x1200+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F08%2F07%2F5bd3327d4d7bb0aef33003377b1c%2Fstanding-buddha-750-850-ce-thailand-likely-from-prasat-hin-khao-plai-bat-ii-buriram-province-bronze-asian-art-museum-of-san-francisco-the-avery-brundage-collection-b65b70-photograph-asian-art-museum-6.jpg" class="img" alt="One of the statues on display ijn the Moving Objects exhibition at The Asian Art Museum of San Francisco. Standing Buddha, 750-850 CE, Thailand, likely from Prasat Hin Khao Plai Bat II, Buriram Province, Bronze." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 One of the statues on display in the &lt;em&gt;Moving Objects&lt;/em&gt; exhibition: Standing Buddha, 750-850 CE, Thailand, likely from Prasat Hin Khao Plai Bat II, Buriram Province, Bronze.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Asian Art Museum of San Francisco                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;h3 class="edTag"&gt;Talking to the public&lt;/h3&gt;   &lt;p&gt;The Asian Art Museum is just one institution confronting these competing forces out in the open.  &lt;/p&gt;   &lt;div id="resnx-s1-5260960-102" class="bucketwrap internallink insettwocolumn inset2col"&gt;                     &lt;!-- END CLASS="BUCKET IMG" --&gt;    &lt;/div&gt;     &lt;!-- END ID="RESNX-S1-5260960-102" CLASS="BUCKETWRAP INTERNALLINK INSETTWOCOLUMN INSET2COL " --&gt;    &lt;p&gt;There's also an &lt;a href="https://www.si.edu/newsdesk/releases/national-museum-african-art-displays-nine-benin-bronzes-loan-government-nigeria" target="_blank"&gt;exhibition&lt;/a&gt; at the Smithsonian's National Museum of African Art in Washington, D.C., which tells the story of sculptures stolen during a British raid on Benin City, Nigeria, in the late 1800s. The Smithsonian repatriated 29 of these co-called "Benin Bronzes" in its collection in 2022, and borrowed nine back from the Nigerian government for the exhibition. &lt;/p&gt;   &lt;div id="resg-s1-44049" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 4284;         --source-height: 5712;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4284x5712+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fe5%2Fbfcc9f76496887f4dcc9000f457a%2Fimg-0176.jpeg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4284x5712+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fe5%2Fbfcc9f76496887f4dcc9000f457a%2Fimg-0176.jpeg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4284x5712+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fe5%2Fbfcc9f76496887f4dcc9000f457a%2Fimg-0176.jpeg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4284x5712+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fe5%2Fbfcc9f76496887f4dcc9000f457a%2Fimg-0176.jpeg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4284x5712+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fe5%2Fbfcc9f76496887f4dcc9000f457a%2Fimg-0176.jpeg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4284x5712+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Faa%2Fe5%2Fbfcc9f76496887f4dcc9000f457a%2Fimg-0176.jpeg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4284x5712+0+0/resize/1800/quality/85/format/webp/?ur