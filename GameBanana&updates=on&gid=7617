    <item>
      <title>Zonaite MKII Weapons</title>
      <author>Happy Mask Salesman</author>
      <link>https://gamebanana.com/mods/565415</link>
      <comments>https://gamebanana.com/mods/565415#PostsListModule</comments>
      <guid isPermaLink="false">0d5e536aac3c75c765876dcf6402fe681a7b0ae5</guid>
      <pubDate>Sun, 29 Dec 2024 04:33:24 +0000</pubDate>
      <description>&lt;img src="https://images.gamebanana.com/img/ss/mods/6770d17d30ce0.jpg"/&gt;&lt;img src="https://images.gamebanana.com/img/ss/mods/6770d1f1272b3.jpg"/&gt;&lt;img src="https://images.gamebanana.com/img/ss/mods/6770d1f0e5621.jpg"/&gt;&lt;img src="https://images.gamebanana.com/img/ss/mods/6770d0b6a3c04.jpg"/&gt;&lt;img src="https://images.gamebanana.com/img/ss/mods/6770d0b70dd58.jpg"/&gt;&lt;img src="https://images.gamebanana.com/img/ss/mods/6770d0b512d80.jpg"/&gt;&lt;img src="https://images.gamebanana.com/img/ss/mods/6770d0b6c02f6.jpg"/&gt;&lt;img src="https://images.gamebanana.com/img/ss/mods/6770d0b525fb6.jpg"/&gt;&lt;img src="https://images.gamebanana.com/img/ss/mods/6770d0b65bf79.jpg"/&gt;&lt;img src="https://images.gamebanana.com/img/ss/mods/6770d0b5a6f46.jpg"/&gt;&lt;img src="https://images.gamebanana.com/img/ss/mods/6770d0b6afa76.jpg"/&gt;&lt;br&gt;This mod adds a set of Zonaite MKII weapons. They can be found in the three ground labyrinths.&lt;br&gt;This mod is included in the &lt;a href="https://gamebanana.com/wips/86031"&gt;Ganondorf's Return project&lt;/a&gt;.&lt;br&gt;&lt;span class="RedColor"&gt;CREDIT TO SHADOWMARTH JTW FOR INSPIRATION!&lt;/span&gt;</description>
