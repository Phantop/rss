    <item>
      <title>Horse Call Whistle - Fourth dungeon item.</title>
      <author>Porroman420</author>
      <link>https://gamebanana.com/mods/689790</link>
      <comments>https://gamebanana.com/mods/689790#PostsListModule</comments>
      <guid isPermaLink="false">8d252076c996946d4e5a7c1ccd21518c1d09b66a</guid>
      <pubDate>Sun, 28 Jun 2026 11:09:19 +0000</pubDate>
