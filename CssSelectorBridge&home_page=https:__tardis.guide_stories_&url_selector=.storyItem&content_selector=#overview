ont-bold leading-6 text-xs tracking-widest text-subheader font-serif"&gt;             Written by        &lt;/p&gt;         &lt;p class="text-xs"&gt;             &lt;a class="hover:underline hover:underline-offset-2 text-sm"     href="https://tardis.guide/writer/lisa-mcmullin/"&gt;Lisa McMullin&lt;/a&gt;        &lt;/p&gt;     &lt;/div&gt; &lt;/div&gt; &lt;div class="flex min-w-0 gap-x-6 items-center justify-center"&gt;     &lt;div&gt;&lt;i class="icon fa-light fa-pen text-center"&gt;&lt;/i&gt;&lt;/div&gt;     &lt;div class="min-w-0 flex-auto"&gt;         &lt;p class="uppercase font-bold leading-6 text-xs tracking-widest text-subheader font-serif"&gt;             Publisher        &lt;/p&gt;         &lt;p class="text-xs"&gt;             &lt;a class="hover:underline hover:underline-offset-2 text-sm"     href="https://tardis.guide/publisher/big-finish-productions/"&gt;Big Finish Productions&lt;/a&gt;        &lt;/p&gt;     &lt;/div&gt; &lt;/div&gt; &lt;div class="flex min-w-0 gap-x-6 items-center justify-center"&gt;     &lt;div&gt;&lt;i class="icon fa-light fa-clapperboard text-center"&gt;&lt;/i&gt;&lt;/div&gt;     &lt;div class="min-w-0 flex-auto"&gt;         &lt;p class="uppercase font-bold leading-6 text-xs tracking-widest text-subheader font-serif"&gt;             Directed by        &lt;/p&gt;         &lt;p class="text-xs"&gt;             &lt;a class="hover:underline hover:underline-offset-2 text-sm"     href="https://tardis.guide/director/bethany-weimers/"&gt;Bethany Weimers&lt;/a&gt;        &lt;/p&gt;     &lt;/div&gt; &lt;/div&gt;                                                                                                                                                                                                                                                                                                                                          &lt;div class="synopsis-wrapper mt-8" style="grid-column: 1 / -1;"&gt;                                     &lt;div