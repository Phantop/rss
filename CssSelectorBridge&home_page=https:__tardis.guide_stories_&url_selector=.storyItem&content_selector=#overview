r justify-center min-w-0 gap-x-6"&gt;                                     &lt;div&gt;&lt;i class="text-center icon fa-light fa-watch"&gt;&lt;/i&gt;&lt;/div&gt;                                     &lt;div class="flex-auto min-w-0"&gt;                                         &lt;p                                             class="font-serif text-xs font-bold tracking-widest uppercase text-subheader"&gt;                                             Runtime                                         &lt;/p&gt;                                         &lt;p class="text-sm"&gt;70 minutes&lt;/p&gt;                                     &lt;/div&gt;                                 &lt;/div&gt;                                                                 &lt;div class="flex items-center justify-center min-w-0 gap-x-6"&gt;     &lt;div&gt;&lt;i class="icon fa-light fa-clock-rotate-left text-center"&gt;&lt;/i&gt;&lt;/div&gt;     &lt;div class="flex-auto min-w-0"&gt;         &lt;p class="font-serif text-xs font-bold leading-6 tracking-widest uppercase text-subheader"&gt;             Time Travel        &lt;/p&gt;         &lt;p class="text-xs"&gt;             &lt;a class="text-sm hover:underline hover:underline-offset-2"     href="https://tardis.guide/time-travel/unclear/"&gt;Unclear&lt;/a&gt;        &lt;/p&gt;     &lt;/div&gt; &lt;/div&gt; &lt;div class="flex items-center justify-center min-w-0 contains-spoiler gap-x-6"&gt;     &lt;div&gt;&lt;i class="icon fa-kit fa-trojan-horse"&gt;&lt;/i&gt;&lt;/div&gt;     &lt;div class="flex-auto min-w-0"&gt;         &lt;details class="spoiler" style="--hidden: 'Stargazing, Time Lord Legends, By Royal Command, Fake Regeneration, Flashbacks, The Dark Times, Vampires'"&gt;              &lt;summary&gt;                 &lt;p class="font-serif text-xs font-bold leading-6 tracking-widest uppercase text-subheader"&gt;                     Tropes (Potential Spoilers!)                 &lt;/p&gt;             &lt;/summary&gt;              &lt;p&gt;         