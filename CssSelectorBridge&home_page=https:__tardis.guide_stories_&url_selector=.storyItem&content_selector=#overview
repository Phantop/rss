                       &lt;div class="flex-auto min-w-0"&gt;                                         &lt;p                                             class="font-serif text-xs font-bold leading-6 tracking-widest uppercase text-subheader"&gt;                                             Written by                                        &lt;/p&gt;                                         &lt;p class="text-xs"&gt;                                                                                         &lt;a class="text-sm hover:underline hover:underline-offset-2"                                                 href="https://tardis.guide/writer/simon-guerrier/"&gt;Simon Guerrier&lt;/a&gt;                                         &lt;/p&gt;                                     &lt;/div&gt;                                 &lt;/div&gt;                                  &lt;div class="flex items-center justify-center min-w-0 gap-x-6"&gt;     &lt;div&gt;&lt;i class="icon fa-light fa-palette text-center"&gt;&lt;/i&gt;&lt;/div&gt;     &lt;div class="flex-auto min-w-0"&gt;         &lt;p class="font-serif text-xs font-bold leading-6 tracking-widest uppercase text-subheader"&gt;             Cover Art by        &lt;/p&gt;         &lt;p class="text-xs"&gt;             &lt;a class="text-sm hover:underline hover:underline-offset-2"     href="https://tardis.guide/cover-artist/ryan-aplin/"&gt;Ryan Aplin&lt;/a&gt;        &lt;/p&gt;     &lt;/div&gt; &lt;/div&gt; &lt;div class="flex items-center justify-center min-w-0 gap-x-6"&gt;     &lt;div&gt;&lt;i class="icon fa-light fa-pen text-center"&gt;&lt;/i&gt;&lt;/div&gt;     &lt;div class="flex-auto min-w-0"&gt;         &lt;p class="font-serif text-xs font-bold leading-6 tracking-widest uppercase text-subheader"&gt;             Publisher        &lt;/p&gt;         &lt;p class="text-xs"&gt;             &lt;a class="text-sm hover:underline hover:underline-offset-2"     href="https://tardis.guide/publisher/big-finish-productions/"&gt;Big Finish Productions&lt;/a&gt;        &lt;/p&gt;     &lt;/div&gt; &lt;/div&gt; &lt;div class="flex items-center justify-center min-w-0 gap-x-6"&gt;     &lt;div&gt;&lt;i class="icon fa-light fa-clapperboard text-center"&gt;&lt;/i&gt;&lt;/div&gt;     &lt;div class="flex-auto min-w-0"&gt;         &lt;p class="font-serif text-xs font-bold leading-6 tracking-widest uppercase text-subheader"&gt;             Directed by        &lt;/p&gt;         &lt;p class="text-xs"&gt;             &lt;a class="text-sm hover:underline hover:underline-offset-2"     href="https://tardis.guide/director/jonathan-s-powell/"&gt;Jonathan S Powell&lt;/a&gt;        &lt;/p&gt;     &lt;/div&gt; &lt;/div&gt;                                                                                                     &lt;div class="flex items-center justify-center min-w-0 gap-x-6"&gt;                                     &lt;div&gt;&lt;i class="text-center icon fa-light fa-watch"&gt;&lt;/i&gt;&lt;/div&gt;                                     &lt;div class="flex-auto min-w-0"&gt;                                         &lt;p                                             class="font-serif text-xs font-bold tracking-widest uppercase text-subheader"&gt;                                             Runtime                                         &lt;/p&gt;                                         &lt;p class="text-sm"&gt;55 minutes&lt;/p&gt;                                     &lt;/div&gt;                                 &lt;/div&gt;                                                                 &lt;div class="flex items-center justify-center min-w-0 gap-x-6"&gt;     &lt;div&gt;&lt;i class="icon fa-light fa-clock-rotate-left text-center"&gt;&lt;/i&gt;&lt;/div&gt;     &lt;div class="flex-auto min-w-0"&gt;         &lt;p class="font-serif text-xs font-bold leading-6 tracking-widest uppercase text-subheader"&gt;             Time Travel        &lt;/p&gt;         &lt;p class="text-xs"&gt;             &lt;a class="text-sm hover:underline hove