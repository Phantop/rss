          Written by                                        &lt;/p&gt;                                         &lt;p class="text-xs"&gt;                                                                                         &lt;a class="text-sm hover:underline hover:underline-offset-2"                                                 href="https://tardis.guide/writer/stewart-pringle/"&gt;Stewart Pringle&lt;/a&gt;,                                             &lt;a class="text-sm hover:underline hover:underline-offset-2"                                                 href="https://tardis.guide/writer/lauren-mooney/"&gt;Lauren Mooney&lt;/a&gt;                                         &lt;/p&gt;                                     &lt;/div&gt;                                 &lt;/div&gt;                                  &lt;div class="flex items-center justify-center min-w-0 gap-x-6"&gt;     &lt;div&gt;&lt;i class="icon fa-light fa-palette text-center"&gt;&lt;/i&gt;&lt;/div&gt;     &lt;div class="flex-auto min-w-0"&gt;         &lt;p class="font-serif text-xs font-bold leading-6 tracking-widest uppercase text-subheader"&gt;             Cover Art by        &lt;/p&gt;                 &lt;p class="text-xs"&gt;             &lt;a class="text-sm hover:underline hover:underline-offset-2"     href="https://tardis.guide/cover-artist/soundsmyth-creative/"&gt;Soundsmyth Creative&lt;/a&gt;        &lt;/p&gt;             &lt;/div&gt; &lt;/div&gt; &lt;div class="flex items-center justify-center min-w-0 gap-x-6"&gt;     &lt;div&gt;&lt;i class="icon fa-light fa-pen text-center"&gt;&lt;/i&gt;&lt;/div&gt;     &lt;div class="flex-auto min-w-0"&gt;         &lt;p class="font-serif text-xs font-bold leading-6 tracking-widest uppercase text-subheader"&gt;             Publisher        &lt;/p&gt;                 &lt;p class="text-xs"&gt;             &lt;a class="text-sm hover:underline hover:underline-offset-2"     href="https://tardis.guide/publisher/big-finish-productions/"&gt;Big Finish Produc