                                    &lt;/p&gt;                                     &lt;/div&gt;                                 &lt;/div&gt;                                  &lt;div class="flex items-center justify-center min-w-0 gap-x-6"&gt;     &lt;div&gt;&lt;i class="icon fa-light fa-pen text-center"&gt;&lt;/i&gt;&lt;/div&gt;     &lt;div class="flex-auto min-w-0"&gt;         &lt;p class="font-serif text-xs font-bold leading-6 tracking-widest uppercase text-subheader"&gt;             Publisher        &lt;/p&gt;         &lt;p class="text-xs"&gt;             &lt;a class="text-sm hover:underline hover:underline-offset-2"     href="https://tardis.guide/publisher/penguin-random-house/"&gt;Penguin Random House&lt;/a&gt;        &lt;/p&gt;     &lt;/div&gt; &lt;/div&gt;                                                                     &lt;div class="flex items-center justify-center min-w-0 gap-x-6"&gt;                                     &lt;div&gt;&lt;i class="text-center icon fa-light fa-book-open-cover"                                             style="transform: scale(.9); position: relative; left: -1px;"&gt;&lt;/i&gt;                                     &lt;/div&gt;                                     &lt;div class="flex-auto min-w-0"&gt;                                         &lt;p                                             class="font-serif text-xs font-bold tracking-widest uppercase text-subheader"&gt;                                             Pages                                         &lt;/p&gt;                                         &lt;p class="text-sm"&gt;304&lt;/p&gt;                                     &lt;/div&gt;                                 &lt;/div&gt;                                                                                                  &lt;div class="flex items-center justify-center min-w-0 gap-x-6"&gt;     &lt;div&gt;&lt;i class="icon fa-light fa-clock-rotate-left text-center"&gt;&lt;/i&gt;&lt;/div&gt;     &lt;div class="flex-au