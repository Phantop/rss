3/default/strip/false/crop/3000x2000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fed%2Fd8%2F8e391c87453ebd7920bebcbe63c2%2F605a7883.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2000+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fed%2Fd8%2F8e391c87453ebd7920bebcbe63c2%2F605a7883.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x2000+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fed%2Fd8%2F8e391c87453ebd7920bebcbe63c2%2F605a7883.jpg" class="img" alt="A driver-mechanic with the call sign Molfar (right), the unit&amp;#039;s commander call-signed Grizzly (center) and a gunner with the call sign Psycho are on a BMP-1, a modernized Soviet-era infantry fighting vehicle, before a mission to the coast of Dnipro River, in Ukraine&amp;#039;s Kherson region, on Jan. 4." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 A driver-mechanic with the call sign Molfar (right), the unit's commander call-signed Grizzly (center) and a gunner with the call sign Psycho are on a BMP-1, a modernized Soviet-era infantry fighting vehicle, before a mission to the coast of Dnipro River, in Ukraine's Kherson region, on Jan. 4.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Anton Shtuka for NPR                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;Just before dark, six Ukrainian soldiers climbed down a ramp into a trench hidden beneath a forested hill near the Dnipro River. Behind camouflage netting, they operate a massive armored vehicle they call Nike, used to prevent Russian forces from crossing the river and seizing Kherson. Roman Kostenko, a former military commander and current member of Ukraine's parliament, says the Kremlin clearly aims to take control of the city to establish dominance over the Black Sea and support military operations in southern Ukraine towards Odesa.&lt;br&gt;&lt;/p&gt;   &lt;ul class="edTag"&gt;&lt;li&gt;📷 Read more about the unit and &lt;a href="https://www.npr.org/2025/01/28/nx-s1-5257409/russia-ukraine-war-soviet-weapons" target="_blank"&gt;see photos inside the mission&lt;/a&gt;.&lt;/li&gt;&lt;/ul&gt;   &lt;h3 class="edTag"&gt;Today's Listen&lt;/h3&gt;   &lt;div id="res734005989" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 1500;         --source-height: 985;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=400&amp;c=85&amp;f=webp 400w, https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=600&amp;c=85&amp;f=webp 600w, https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=800&amp;c=85&amp;f=webp 800w, https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=900&amp;c=85&amp;f=webp 900w, https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=1200&amp;c=85&amp;f=webp 1200w, https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=1600&amp;c=85&amp;f=webp 1600w, https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=1800&amp;c=85&amp;f=webp 1800w" data-template="https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s={width}&amp;c={quality}&amp;f={format}" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=400&amp;c=85&amp;f=jpeg 400w, https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=600&amp;c=85&amp;f=jpeg 600w, https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=800&amp;c=85&amp;f=jpeg 800w, https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=900&amp;c=85&amp;f=jpeg 900w, https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=1200&amp;c=85&amp;f=jpeg 1200w, https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=1600&amp;c=85&amp;f=jpeg 1600w, https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=1800&amp;c=85&amp;f=jpeg 1800w" data-template="https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s={width}&amp;c={quality}&amp;f={format}" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s=1100&amp;c=50&amp;f=jpeg" data-template="https://media.npr.org/assets/img/2019/06/19/imogen1_custom-cce43146c910279b2ae714d70bc4e7c812d01a4c.jpg?s={width}&amp;c={quality}&amp;f={format}" class="img" alt="Imogen Heap plays a Tiny Desk Conert on May 4, 2019 (Colin Marshall/NPR)." loading="lazy" /&gt;         &lt;/picture&gt;          &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Imogen Heap plays a Tiny Desk Conert on May 4, 2019 (Colin Marshall/NPR).                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Colin Marshall/NPR                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;      &lt;/div&gt;    &lt;p&gt;Imogen Heap's song "Headlock" debuted on &lt;em&gt;Billboard&lt;/em&gt;'s Hot 100 at No.100 last week and climbed to No. 98 this week. Her career stretches roughly three decades, but she has never landed one of her songs on the main pop chart until now. The song, which is from her 2005 album &lt;em&gt;Speak For Yourself&lt;/em&gt;, received a resurgence with the help of a social media trend. Listen to &lt;a href="https://one.npr.org/?sharedMediaId=nx-s1-5276087:nx-s1-5341066-1" target="_blank"&gt;snippets of the song&lt;/a&gt; and &lt;a href="https://www.npr.org/2025/01/29/nx-s1-5276087/imogen-heaps-song-headlock-hits-billboard-charts-20-years-after-it-was-released" target="_blank"&gt;read more about the other songs&lt;/a&gt; making up the charts this week.&lt;br&gt;&lt;/p&gt;       &lt;h3 class="edTag"&gt;3 things to know before you go&lt;/h3&gt;   &lt;div id="resg-s1-45262" class="bucketwrap image large"&gt;         