m/dims3/default/strip/false/crop/1780x1001+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa9%2F36%2F34737d734ec5b0eaf5c7a37f3df4%2F186071607-r-shawn-bohs-npr.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1780x1001+0+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa9%2F36%2F34737d734ec5b0eaf5c7a37f3df4%2F186071607-r-shawn-bohs-npr.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1780x1001+0+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa9%2F36%2F34737d734ec5b0eaf5c7a37f3df4%2F186071607-r-shawn-bohs-npr.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1780x1001+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa9%2F36%2F34737d734ec5b0eaf5c7a37f3df4%2F186071607-r-shawn-bohs-npr.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1780x1001+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa9%2F36%2F34737d734ec5b0eaf5c7a37f3df4%2F186071607-r-shawn-bohs-npr.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1780x1001+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa9%2F36%2F34737d734ec5b0eaf5c7a37f3df4%2F186071607-r-shawn-bohs-npr.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1780x1001+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa9%2F36%2F34737d734ec5b0eaf5c7a37f3df4%2F186071607-r-shawn-bohs-npr.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1780x1001+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa9%2F36%2F34737d734ec5b0eaf5c7a37f3df4%2F186071607-r-shawn-bohs-npr.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1780x1001+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa9%2F36%2F34737d734ec5b0eaf5c7a37f3df4%2F186071607-r-shawn-bohs-npr.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1780x1001+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa9%2F36%2F34737d734ec5b0eaf5c7a37f3df4%2F186071607-r-shawn-bohs-npr.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1780x1001+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa9%2F36%2F34737d734ec5b0eaf5c7a37f3df4%2F186071607-r-shawn-bohs-npr.jpg" class="img" alt="Emory Bohs leans down to shave Alan Hirsch." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Emory Bohs leans down to shave Alan Hirsch.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          R. Shawn Bohs                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;For 57-year-old R. Shawn Bohs, of Prairie Village, Kan., this image is a "poignant expression of hope" that stays with him. He captured his son, Emory Bohs, shaving his father-in-law, Alan Hirsch, who was unable to lift his arms and do the task himself. Alan was at a rehabilitation facility recovering after he was hospitalized for serious medical complications related to Parkinson's disease. R. Shawn has taken over 50,000 photos professionally, but this one sticks out. He says that at a time when he hears that Gen Z is withdrawing from traditional roles, this image reassures him that maybe the opposite is true and that our future is in good hands. R. Shawn says no one put the razor in his son's hands, and he was struck by the way they were with each other. He said he could barely hold himself together as his son spoke in reassuring, soft tones to Alan. "We are all in this life together and we depend on our shared humanity to get through it," R. Shawn said. "One shave at a time."&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;R. Shawn's tip:&lt;/strong&gt; "Shoot what you know. Follow what compels you, even in the most mundane settings. Listen to what speaks to you and you will see the opportunity."&lt;/p&gt;   &lt;div id="resg-s1-82941" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 4160;         --source-height: 2340;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4160x2340+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F6f%2Fdc%2F19b075174044b2bf341d9e494628%2F186071607-20160827-13-23-39.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4160x2340+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F6f%2Fdc%2F19b075174044b2bf341d9e494628%2F186071607-20160827-13-23-39.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4160x2340+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F6f%2Fdc%2F19b075174044b2bf341d9e494628%2F186071607-20160827-13-23-39.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4160x2340+0+0/resize/900/quality/85/format/webp