et="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8192x4608+0+156/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F7f%2F87%2Fa870b313462ca20cdac3670321d4%2Fhttps-cdn-sanity-io-images-xq1bjtf4-production-1378f0add48547526644a395c0c360da408aee0e-8640x5760.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8192x4608+0+156/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F7f%2F87%2Fa870b313462ca20cdac3670321d4%2Fhttps-cdn-sanity-io-images-xq1bjtf4-production-1378f0add48547526644a395c0c360da408aee0e-8640x5760.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8192x4608+0+156/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F7f%2F87%2Fa870b313462ca20cdac3670321d4%2Fhttps-cdn-sanity-io-images-xq1bjtf4-production-1378f0add48547526644a395c0c360da408aee0e-8640x5760.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8192x4608+0+156/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F7f%2F87%2Fa870b313462ca20cdac3670321d4%2Fhttps-cdn-sanity-io-images-xq1bjtf4-production-1378f0add48547526644a395c0c360da408aee0e-8640x5760.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8192x4608+0+156/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F7f%2F87%2Fa870b313462ca20cdac3670321d4%2Fhttps-cdn-sanity-io-images-xq1bjtf4-production-1378f0add48547526644a395c0c360da408aee0e-8640x5760.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8192x4608+0+156/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F7f%2F87%2Fa870b313462ca20cdac3670321d4%2Fhttps-cdn-sanity-io-images-xq1bjtf4-production-1378f0add48547526644a395c0c360da408aee0e-8640x5760.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8192x4608+0+156/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F7f%2F87%2Fa870b313462ca20cdac3670321d4%2Fhttps-cdn-sanity-io-images-xq1bjtf4-production-1378f0add48547526644a395c0c360da408aee0e-8640x5760.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8192x4608+0+156/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F7f%2F87%2Fa870b313462ca20cdac3670321d4%2Fhttps-cdn-sanity-io-images-xq1bjtf4-production-1378f0add48547526644a395c0c360da408aee0e-8640x5760.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8192x4608+0+156/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F7f%2F87%2Fa870b313462ca20cdac3670321d4%2Fhttps-cdn-sanity-io-images-xq1bjtf4-production-1378f0add48547526644a395c0c360da408aee0e-8640x5760.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8192x4608+0+156/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F7f%2F87%2Fa870b313462ca20cdac3670321d4%2Fhttps-cdn-sanity-io-images-xq1bjtf4-production-1378f0add48547526644a395c0c360da408aee0e-8640x5760.jpg" class="img" alt="Hugh Jackman as Robin Hood." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Hugh Jackman as Robin Hood.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          A24                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;Check out what &lt;/strong&gt;&lt;a href="https://www.npr.org/sections/culture/" target="_blank"&gt;&lt;strong&gt;NPR&lt;/strong&gt;&lt;/a&gt;&lt;strong&gt; is watching, reading and listening to this weekend:&lt;/strong&gt;&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🍿 Movies:&lt;/strong&gt; Hugh Jackman stars in &lt;a href="https://www.npr.org/2026/06/18/nx-s1-5858925/the-death-of-robin-hood-review-hugh-jackman" target="_blank"&gt;&lt;em&gt;The Death of Robin Hood&lt;/em&gt;&lt;/a&gt; as the legendary hero who robs from the rich and gives to the poor. During the film, he grapples with what his youthful righting of wrongs has cost him and bystanders alike.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;📺 TV:&lt;/strong&gt; &lt;a href="https://www.npr.org/2026/06/16/nx-s1-5855729/widows-bay-is-an-island-in-the-scream" target="_blank"&gt;&lt;em&gt;Widow's Bay&lt;/em&gt;&lt;/a&gt; blends horror and comedy as it follows a mayor who desperately tries to bring tourism to a small island town that might be cursed.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;📚 Books: &lt;/strong&gt;Summer offers the perfect opportunity to dive into great books released in spring. NPR's &lt;em&gt;Fresh Air&lt;/em&gt; book critic Maureen Corrigan did just that with &lt;em&gt;The Family Man&lt;/em&gt; by James Lasdun, &lt;em&gt;The Hill&lt;/em&gt; by Harriet Clark and &lt;em&gt;A Beautiful Loan&lt;/em&gt; by Mary Costello. Check out &lt;a href="https://www.npr.org/2026/06/15/nx-s1-5856245/summer-books-reviews" target="_blank"&gt;her reviews of these titles&lt;/a&gt;.&lt;/p&gt;       &lt;p&gt;&lt;strong&gt;🎵 Music:&lt;/strong&gt; New music from Tierra Whack, The War and Treaty and more has hit streaming platforms today. NPR Music has prepared a &lt;a href="https://www.npr.org/2026/06/19/nx-s1-5830356/new-music-friday-best-albums-june-19-2026" target="_blank"&gt;playlist featuring singles&lt;/a&gt; from several new albums.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;❓Quiz:&lt;/strong&gt; The World Cup, the Kennedy Center and Kevin Warsh were some of the topics that made headlines this week and now they have made an &lt;a href="http://npr.org/2026/06/19/g-s1-128757/world-cup-trump-messi-ai-el-nino-newsom-news-quiz" target="_blank"&gt;appearance in this week's test&lt;/a&gt;.&lt;/p&gt;   &lt;h3 class="edTag"&gt;3 things to know before you go&lt;/h3&gt;   &lt;div id="resg-s1-128991" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 4000;         --source-height: 2250;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+209/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F51%2F0b%2Fa3aff052462fa08a759eea194e57%2Fap26168502462566.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+209/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F51%2F0b%2Fa3aff052462fa08a759eea194e57%2Fap26168502462566.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+209/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F51%2F0b%2Fa3aff052462fa08a759eea194e57%2Fap26168502462566.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+209/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F51%2F0b%2Fa3aff052462fa08a759eea194e57%2Fap26168502462566.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+209/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F51%2F0b%2Fa3aff052462fa08a759eea194e57%2Fap26168502462566.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+209/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F51%2F0b%2Fa3aff052462fa08a759eea194