4e269060ac2d%2Fswitch-16x9-thelegendofzelda-echoesofwisdom-keyart-1000x563.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1000x563+0+1/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F74%2F0f%2F7900d1c3423190f04e269060ac2d%2Fswitch-16x9-thelegendofzelda-echoesofwisdom-keyart-1000x563.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1000x563+0+1/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F74%2F0f%2F7900d1c3423190f04e269060ac2d%2Fswitch-16x9-thelegendofzelda-echoesofwisdom-keyart-1000x563.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1000x563+0+1/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F74%2F0f%2F7900d1c3423190f04e269060ac2d%2Fswitch-16x9-thelegendofzelda-echoesofwisdom-keyart-1000x563.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1000x563+0+1/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F74%2F0f%2F7900d1c3423190f04e269060ac2d%2Fswitch-16x9-thelegendofzelda-echoesofwisdom-keyart-1000x563.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1000x563+0+1/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F74%2F0f%2F7900d1c3423190f04e269060ac2d%2Fswitch-16x9-thelegendofzelda-echoesofwisdom-keyart-1000x563.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1000x563+0+1/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F74%2F0f%2F7900d1c3423190f04e269060ac2d%2Fswitch-16x9-thelegendofzelda-echoesofwisdom-keyart-1000x563.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1000x563+0+1/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F74%2F0f%2F7900d1c3423190f04e269060ac2d%2Fswitch-16x9-thelegendofzelda-echoesofwisdom-keyart-1000x563.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1000x563+0+1/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F74%2F0f%2F7900d1c3423190f04e269060ac2d%2Fswitch-16x9-thelegendofzelda-echoesofwisdom-keyart-1000x563.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1000x563+0+1/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F74%2F0f%2F7900d1c3423190f04e269060ac2d%2Fswitch-16x9-thelegendofzelda-echoesofwisdom-keyart-1000x563.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1000x563+0+1/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F74%2F0f%2F7900d1c3423190f04e269060ac2d%2Fswitch-16x9-thelegendofzelda-echoesofwisdom-keyart-1000x563.jpg" class="img" alt="The cover art for the new Legends of Zelda game on Switch." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 "The Legend of Zelda: Echoes of Wisdom" casts Zelda in the starring role.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Nintendo                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;The Zelda series has been around for nearly four decades, but the princess the game is named after has not had a spotlight role until recently. &lt;/strong&gt;Instead, the green hat-clad Link plays the protagonist, saving the world from evil and rescuing Princess Zelda. She now flips the script by grabbing her wand to save a trapped Link in the series' latest addition, The Legend of Zelda: Echoes of Wisdom. &lt;br&gt;&lt;/p&gt;   &lt;ul class="edTag"&gt;&lt;li&gt;🎧 &lt;strong&gt;Listen and watch &lt;/strong&gt;&lt;em&gt;Morning Edition&lt;/em&gt; host Leila Fadel discuss the &lt;a href="https://www.npr.org/2024/09/25/nx-s1-5119337/zelda-is-her-own-hero-in-the-series-latest-the-legend-of-zelda-echoes-of-wisdom"&gt;significance of this role reversal&lt;/a&gt; with and Amanda Cote, author of &lt;em&gt;Gaming Sexism: Gender and Identity in the Era of Casual Video Games&lt;/em&gt;.&lt;/li&gt;&lt;/ul&gt;   &lt;h3 class="edTag"&gt;Picture show&lt;/h3&gt;   &lt;div id="res784864508" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 4200;         --source-height: 2362;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=400&amp;c=85&amp;f=webp 400w, https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=600&amp;c=85&amp;f=webp 600w, https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=800&amp;c=85&amp;f=webp 800w, https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=900&amp;c=85&amp;f=webp 900w, https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=1200&amp;c=85&amp;f=webp 1200w, https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=1600&amp;c=85&amp;f=webp 1600w, https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=1800&amp;c=85&amp;f=webp 1800w" data-template="https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s={width}&amp;c={quality}&amp;f={format}" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=400&amp;c=85&amp;f=jpeg 400w, https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=600&amp;c=85&amp;f=jpeg 600w, https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=800&amp;c=85&amp;f=jpeg 800w, https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=900&amp;c=85&amp;f=jpeg 900w, https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=1200&amp;c=85&amp;f=jpeg 1200w, https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=1600&amp;c=85&amp;f=jpeg 1600w, https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=1800&amp;c=85&amp;f=jpeg 1800w" data-template="https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s={width}&amp;c={quality}&amp;f={format}" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s=1100&amp;c=50&amp;f=jpeg" data-template="https://media.npr.org/assets/img/2019/12/04/gettyimages-1140189994_wide-1767022f07f561a47a9dc9751f0f801cf5b7c220.jpg?s={width}&amp;c={quality}&amp;f={format}" class="img" alt="Former President Jimmy Carter attends Maranatha Baptist Church before teaching Sunday school in his hometown of Plains, Ga., in April. Carter was released from a hospital Wednesday following treatment for an infection." loading="lazy" /&gt;         &lt;/picture&gt;          &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Former President Jimmy Carter attends Maranatha Baptist Church before teaching Sunday school in his hometown of Plains, Ga., in April. Carter was released from a hospital Wednesday following treatment for an infection.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          NurPhoto/NurPhoto via Getty Images                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;      &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;Former President Jimmy Carter was born on Oct. 1, 1924, and yesterday marked his centennial birthday.&lt;/strong&gt; The 39th president, who has been in home hospice care since February 2023, received birthday wishes from many, including President Biden. His birthplace of Plains, Ga., held a parade in his honor. Carter is the longest-living person to have served as a U.S. president. &lt;br&gt;&lt;/p&gt;   &lt;ul class="edTag"&gt;&lt;li&gt;📷 &lt;strong&gt;See photos&lt;/strong&gt; of the former president through &lt;a href="https://www.npr.org/sections/the-picture-show/2024/09/30/nx-s1-5133493/photos-jimmy-carter-birthday-100-years"&gt;notable events throughout the decades&lt;/a&gt; of his life.&lt;/li&gt;&lt;/ul&gt;       &lt;h3 class="edTag"&gt;3 things to know before you go&lt;/h3&gt;   &lt;div id="resg-s1-25788" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 2077;         --source-height: 1385;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2077x1385+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F29%2Ff9%2F86a891b7479cb9c66bea768314b6%2Fap24275636536871.jpg" class="img" alt="President Claudia Sheinbaum wears the presidential sash during her swearing-in ceremony as Mexico's new president in Mexico City, October 1 2024" loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 President Claudia Sheinbaum wears the presidential sash during her swearing-in ceremony as Mexico's new president in Mexico City, October 1 2024                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Eduardo Verdugo/AP                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;ol class="edTag"&gt;&lt;li&gt;&lt;strong&gt;Claudia Sheinbaum, a former mayor of Mexico City, became Mexico’s 66th president&lt;/strong&gt; and first female leader yesterday. She won with nearly 60% of the vote. Here are &lt;a href="https://www.npr.org/2024/10/01/nx-s1-5134570/mexico-has-a-new-president-and-its-first-female-leader-in-an-historic-inauguration-day"&gt;five things to know about her&lt;/a&gt;.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Fat Bear Week, a celebration of brown bears’ survival instincts, was delayed&lt;/strong&gt; Monday after a &lt;a href="https://www.npr.org/2024/10/01/nx-s1-5134907/fat-bear-week-start-delayed-bear-killed"&gt;male bear, 469, killed a female&lt;/a&gt;, 402, at Katmai National Park &amp; Preserve in Alaska.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;In 2001, Nora Durkin decided to pick up the phone and call 311 to talk about a secret&lt;/strong&gt; she kept since she was a child. The operator, her unsung hero, &lt;a href="https://www.npr.org/2024/09/30/nx-s1-5132063/311-line-abuse-hope-kindness"&gt;gave her the affirmation she needed&lt;/a&gt; for years and helped provide her with guidance that brought her peace. &lt;strong&gt;&lt;em&gt;Editor's note: &lt;/em&gt;&lt;/strong&gt;&lt;em&gt;This story mentions child sexual abuse. If you or someone you know has experienced sexual violence, you can receive free, confidential support by calling the &lt;/em&gt;&lt;a href="https://rainn.org/resources"&gt;&lt;em&gt;National Sexual Assault Hotline&lt;/em&gt;&lt;/a&gt;&lt;em&gt; at 800-656-HOPE.&lt;/em&gt;&lt;/li&gt;&lt;/ol&gt;   &lt;p&gt;&lt;em&gt;This newsletter was edited by &lt;/em&gt;&lt;a href="https://www.npr.org/people/g-s1-2467/obed-manuel"&gt;&lt;em&gt;Suzanne Nuyen.&lt;/em&gt;&lt;/a&gt;&lt;/p&gt; &lt;/div&gt;</description>
