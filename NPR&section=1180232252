efault/strip/false/crop/2000x1125+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F00%2Ff9%2F59b18e2c4195bdea85b5de9cde2d%2Fcopy-of-6-book-covers-2.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1125+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F00%2Ff9%2F59b18e2c4195bdea85b5de9cde2d%2Fcopy-of-6-book-covers-2.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1125+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F00%2Ff9%2F59b18e2c4195bdea85b5de9cde2d%2Fcopy-of-6-book-covers-2.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1125+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F00%2Ff9%2F59b18e2c4195bdea85b5de9cde2d%2Fcopy-of-6-book-covers-2.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1125+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F00%2Ff9%2F59b18e2c4195bdea85b5de9cde2d%2Fcopy-of-6-book-covers-2.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1125+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F00%2Ff9%2F59b18e2c4195bdea85b5de9cde2d%2Fcopy-of-6-book-covers-2.jpg" class="img" alt="Book covers of: Love Forms; The South; Universality; One Boat; Flashlight; The Loneliness of Sonia and Sunny; Audition; The Rest of Our Lives; The Land in Winter; Endling; Flesh; Seascraper; Misinterpretation" loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;         &lt;/div&gt;       &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;ol class="edTag"&gt;&lt;li&gt;This year's &lt;a href="https://www.npr.org/2025/07/29/nx-s1-5482914/2025-booker-prize-longlist-fiction" target="_blank"&gt;longlist for the Booker Prize&lt;/a&gt; was announced yesterday. Among the 13 books on the list for this prestigious award are two debut novelists.&lt;/li&gt;&lt;li&gt;Tennessee leaders announced Monday that Elon Musk's Boring Company has &lt;a href="https://wpln.org/post/nashville-partners-with-elon-musk-to-bring-tesla-tunnel-to-bna-airport/" target="_blank"&gt;plans for an underground passageway&lt;/a&gt; that would transport people from downtown Nashville to Nashville International Airport more quickly. (via &lt;a href="https://wpln.org/" target="_blank"&gt;WPLN&lt;/a&gt;)&lt;/li&gt;&lt;li&gt;Fleetwood Mac fans, listen up! Stevie Nicks and Lindsey Buckingham are revisiting their root by &lt;a href="https://www.npr.org/2025/07/29/nx-s1-5483555/stevie-nicks-lindsey-buckingham-album-reissue-fleetwood-mac-history" target="_blank"&gt;reissuing &lt;em&gt;Buckingham Nicks&lt;/em&gt;&lt;/a&gt;, the only studio album they recorded as a duo of the same name.&lt;/li&gt;&lt;/ol&gt;   &lt;p&gt;&lt;em&gt;This newsletter was edited by &lt;/em&gt;&lt;a href="https://www.npr.org/people/859721331/suzanne-nuyen"target="_blank"   &gt;&lt;strong&gt;&lt;em&gt;Suzanne Nuyen&lt;/em&gt;&lt;/strong&gt;&lt;/a&gt;&lt;em&gt;.&lt;/em&gt;&lt;/p&gt; &lt;/div&gt;</description>
