ault/strip/false/crop/2400x1601+0+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fed%2F05%2F6f88963944a68ae19063672c5f6d%2F20241225-bbowl-005-1.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2400x1601+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fed%2F05%2F6f88963944a68ae19063672c5f6d%2F20241225-bbowl-005-1.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2400x1601+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fed%2F05%2F6f88963944a68ae19063672c5f6d%2F20241225-bbowl-005-1.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2400x1601+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fed%2F05%2F6f88963944a68ae19063672c5f6d%2F20241225-bbowl-005-1.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2400x1601+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fed%2F05%2F6f88963944a68ae19063672c5f6d%2F20241225-bbowl-005-1.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2400x1601+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fed%2F05%2F6f88963944a68ae19063672c5f6d%2F20241225-bbowl-005-1.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2400x1601+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fed%2F05%2F6f88963944a68ae19063672c5f6d%2F20241225-bbowl-005-1.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2400x1601+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fed%2F05%2F6f88963944a68ae19063672c5f6d%2F20241225-bbowl-005-1.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2400x1601+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fed%2F05%2F6f88963944a68ae19063672c5f6d%2F20241225-bbowl-005-1.jpg" class="img" alt="Photo by Julian Dakdouk" loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Photo by Julian Dakdouk                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;  &lt;/div&gt;    &lt;/div&gt;    &lt;ol class="edTag"&gt;&lt;li&gt;&lt;strong&gt;Netflix says over 200 countries tuned into the "Beyoncé Bowl" and its two Christmas Day NFL games.&lt;/strong&gt; NPR TV critic Eric Deggans writes that the platform proved it is ready to compete with the big dogs of broadcasting to &lt;a href="https://www.npr.org/2024/12/26/nx-s1-5232865/beyonce-halftime-show-netflix-cowboy-carter-christmas" target="_blank"&gt;offer glitch-free live entertainment&lt;/a&gt;.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;A Washington state animal sanctuary is under quarantine after a bird flu outbreak&lt;/strong&gt; killed 20 big cats, including &lt;a href="https://www.npr.org/2024/12/26/nx-s1-5239841/bird-flu-kills-20-cats-washington-sanctuary" target="_blank"&gt;four cougars and a half-Bengal tiger&lt;/a&gt;, in recent weeks.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Former Indian Prime Minister Manmohan Singh died yesterday at age 92. &lt;/strong&gt;He was known as the &lt;a href="https://www.npr.org/2024/12/26/1045646076/manmohan-singh-dies-india" target="_blank"&gt;father of economic reform in the country&lt;/a&gt;.&lt;/li&gt;&lt;/ol&gt;   &lt;p&gt;&lt;em&gt;This newsletter was edited by &lt;/em&gt;&lt;a href="https://www.npr.org/people/g-s1-2467/obed-manuel"target="_blank"   &gt;&lt;strong&gt;&lt;em&gt;Obed Manuel&lt;/em&gt;&lt;/strong&gt;&lt;/a&gt;&lt;em&gt;.&lt;/em&gt;&lt;/p&gt; &lt;/div&gt;</description>
