pr-brightspot.s3.amazonaws.com%2F55%2F8b%2F3aea17b249d7819f57eaf0371750%2Fgettyimages-2188146258.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8192x4608+0+856/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F55%2F8b%2F3aea17b249d7819f57eaf0371750%2Fgettyimages-2188146258.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/8192x4608+0+856/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F55%2F8b%2F3aea17b249d7819f57eaf0371750%2Fgettyimages-2188146258.jpg" class="img" alt="The choir, clergy and guests stand as they sing during a ceremony to mark the reopening of the landmark Notre Dame Cathedral, in central Paris, on Saturday." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 The choir, clergy and guests stand as they sing during a ceremony to mark the reopening of the landmark Notre Dame Cathedral, in central Paris, on Saturday.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Ludovic Marin/AFP/Getty Images                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;The bells of Notre Dame Cathedral rang for the first time Saturday in Paris since a fire damaged the landmark in 2019. &lt;/strong&gt;The ceremony to mark the cathedral's return to religious services featured guests such as French President Emmanuel Macron, Trump, first lady Jill Biden, Ukrainian President Volodymyr Zelenskyy and the U.K.'s Prince William. The ceremony began with Paris Archbishop Laurent Ulrich knocking three times on the cathedral's door with his staff, which is made from one of the burned beams of the cathedral's roof. &lt;br&gt;&lt;/p&gt;   &lt;ul class="edTag"&gt;&lt;li&gt;📷 &lt;strong&gt;See photos &lt;/strong&gt;from &lt;a href="https://www.npr.org/sections/the-picture-show/2024/12/07/g-s1-37345/photos-notre-dame-cathedral-reopens-macron-trump"&gt;Notre Dame Cathedral's first service&lt;/a&gt; since the devastating fire.&lt;/li&gt;&lt;/ul&gt;   &lt;h3 class="edTag"&gt;3 things to know before you go&lt;/h3&gt;   &lt;div id="resg-s1-37428" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 5601;         --source-height: 3151;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5601x3151+0+292/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbb%2Fef%2F07d9faf842c686637aba5a450d73%2Fap24042839919155.jpg" class="img" alt="Jay-Z is seen before the 2024 Super Bowl football game between the San Francisco 49ers and the Kansas City Chiefs in February, in Las Vegas." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Jay-Z arrives before the NFL Super Bowl 58 football game between the San Francisco 49ers and the Kansas City Chiefs, Sunday, Feb. 11, 2024, in Las Vegas. (AP Photo/Julio Cortez)                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Julio Cortez/AP                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;ol class="edTag"&gt;&lt;li&gt;&lt;strong&gt;Rapper Jay-Z has been accused of drugging and raping a 13-year-old girl&lt;/strong&gt; in 2000, allegedly along with Sean "Diddy" Combs, according to a &lt;a href="https://www.npr.org/2024/12/08/nx-s1-5221691/jay-z-sean-diddy-combs-diddy-suit"&gt;civil lawsuit filed in federal court&lt;/a&gt; yesterday.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;The U.S. Department of Agriculture issued a federal order requiring testing of the country's milk supply &lt;/strong&gt;due to &lt;a href="https://www.npr.org/2024/12/06/nx-s1-5220272/testing-usda-bird-flu-raw-milk-california"&gt;increasing concerns about bird flu&lt;/a&gt;. Since March, the virus has spread to over 710 dairy herds across 15 states.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Workers at Volkswagen, Germany's largest employer, are on strike &lt;/strong&gt;over the &lt;a href="https://one.npr.org/?sharedMediaId=nx-s1-5220357:nx-s1-5286763-1"&gt;company's plans to cut wages&lt;/a&gt;, lay off employees and close factories in Germany.&lt;/li&gt;&lt;/ol&gt;       &lt;p&gt;&lt;em&gt;This newsletter was edited by &lt;/em&gt;&lt;a href="https://www.npr.org/people/859721331/suzanne-nuyen"&gt;&lt;em&gt;Suzanne Nuyen&lt;/em&gt;&lt;/a&gt;&lt;em&gt;.&lt;/em&gt;&lt;/p&gt; &lt;/div&gt;</description>
