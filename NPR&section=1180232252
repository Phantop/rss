66bb2077b2424a7bcc%2F012425-tt-pandas-1.JPG 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4824x3216+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fef%2Fa6%2F3e84f2854166bb2077b2424a7bcc%2F012425-tt-pandas-1.JPG 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4824x3216+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fef%2Fa6%2F3e84f2854166bb2077b2424a7bcc%2F012425-tt-pandas-1.JPG 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4824x3216+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fef%2Fa6%2F3e84f2854166bb2077b2424a7bcc%2F012425-tt-pandas-1.JPG 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4824x3216+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fef%2Fa6%2F3e84f2854166bb2077b2424a7bcc%2F012425-tt-pandas-1.JPG 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4824x3216+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fef%2Fa6%2F3e84f2854166bb2077b2424a7bcc%2F012425-tt-pandas-1.JPG" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4824x3216+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fef%2Fa6%2F3e84f2854166bb2077b2424a7bcc%2F012425-tt-pandas-1.JPG" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4824x3216+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fef%2Fa6%2F3e84f2854166bb2077b2424a7bcc%2F012425-tt-pandas-1.JPG" class="img" alt="Qing Bao, one of the Smithsonian National Zoo’s new Giant Pandas, eats an apple on Friday, Jan. 24, 2025. In November 2023, the National Zoo sent its three pandas — Tian Tian and Mei Xiang, who had lived there since 2000, and their cub Xiao Qi Ji — back to China, in advance of the expiration of their loan agreement and amidst rising tensions between the two countries." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Qing Bao, one of the Smithsonian National Zoo's new Giant Pandas, eats an apple on Friday, Jan. 24, 2025. In November 2023, the National Zoo sent its three pandas — Tian Tian and Mei Xiang, who had lived there since 2000, and their cub Xiao Qi Ji — back to China, in advance of the expiration of their loan agreement and amidst rising tensions between the two countries.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Tyrone Turner/WAMU                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;Panda-monium has officially begun in the nation's capital. &lt;/strong&gt;After a three-month wait and an 8,000-mile trip from China, giant pandas Bao Li and Qing Bao are finally on display at the Smithsonian National Zoo. Their debut marks the latest chapter in China's "&lt;a href="https://www.npr.org/2025/01/24/nx-s1-5272416/panda-diplomacy-china-dc-zoo" target="_blank"&gt;&lt;u&gt;panda diplomacy&lt;/u&gt;&lt;/a&gt;" in the U.S.&lt;br&gt;&lt;/p&gt;   &lt;ul class="edTag"&gt;&lt;li&gt;&lt;strong&gt;📷 See photos &lt;/strong&gt;from their &lt;a href="https://www.npr.org/sections/the-picture-show/2025/01/24/g-s1-44627/photos-pandas-return-national-zoo" target="_blank"&gt;&lt;u&gt;official return&lt;/u&gt;&lt;/a&gt;.&lt;/li&gt;&lt;/ul&gt;   &lt;h3 class="edTag"&gt;3 things to know before you go&lt;/h3&gt;   &lt;div id="resg-s1-44783" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 3088;         --source-height: 2320;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3088x2320+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fbf%2Fcd%2Fd9a361fb4d9ba649d9fd0670d219%2Fclaire-burnside-och-today-3.jpeg" class="img" alt="When Claire Burnside Och was a young waitress, a customer&amp;#039;s unexpected reply put her at ease." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 When Claire Burnside Och was a young waitress, a customer's unexpected reply put her at ease.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Claire Burnside Och                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;ol class="edTag"&gt;&lt;li&gt;&lt;strong&gt;In 2004, Claire Burnside Och was a server at a high-end restaurant when she made a mistake opening a bottle of wine.&lt;/strong&gt; She had broken the cork, leaving half on her corkscrew and the other portion stuck in the bottle. Instead of being annoyed, the customer handled it with grace and left her with words she now &lt;a href="https://www.npr.org/2025/01/27/g-s1-44781/unsung-hero-unexpected-reply-customer" target="_blank"&gt;uses to respond to others' fumbles&lt;/a&gt;.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;The last of the 43 monkeys that escaped from Alpha Genesis Primate Research Center &lt;/strong&gt;in Yemassee, S.C., in November of last year &lt;a href="https://www.npr.org/2025/01/27/g-s1-44925/last-escaped-south-carolina-lab-monkeys-recovered" target="_blank"&gt;&lt;u&gt;have been recovered&lt;/u&gt;&lt;/a&gt;, according to the local police department. &lt;/li&gt;&lt;li&gt;&lt;strong&gt;&lt;em&gt;The First State of Being&lt;/em&gt; and &lt;em&gt;Chooch Helped&lt;/em&gt; have won the Newbery and Caldecott awards&lt;/strong&gt;, respectively — the &lt;a href="https://www.npr.org/2025/01/27/nx-s1-5262542/caldecott-newbery-the-first-state-of-being-chooch-helped" target="_blank"&gt;&lt;u&gt;biggest honors in children's literature&lt;/u&gt;&lt;/a&gt;.&lt;/li&gt;&lt;/ol&gt;       &lt;p&gt;&lt;em&gt;This newsletter was edited by &lt;/em&gt;&lt;a href="https://www.npr.org/people/1155154221/majd-al-waheidi"target="_blank"   &gt;&lt;em&gt;Majd Al-Waheidi&lt;/em&gt;&lt;/a&gt;&lt;em&gt;.&lt;/em&gt;&lt;/p&gt; &lt;/div&gt;</description>
