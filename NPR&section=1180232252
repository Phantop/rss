2F%2Fnpr-brightspot.s3.amazonaws.com%2F64%2F46%2F4d3d19ab40dba0bfe96b88e4b4ca%2Fgettyimages-2258151.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2700x1519+0+141/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F64%2F46%2F4d3d19ab40dba0bfe96b88e4b4ca%2Fgettyimages-2258151.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2700x1519+0+141/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F64%2F46%2F4d3d19ab40dba0bfe96b88e4b4ca%2Fgettyimages-2258151.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2700x1519+0+141/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F64%2F46%2F4d3d19ab40dba0bfe96b88e4b4ca%2Fgettyimages-2258151.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2700x1519+0+141/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F64%2F46%2F4d3d19ab40dba0bfe96b88e4b4ca%2Fgettyimages-2258151.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2700x1519+0+141/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F64%2F46%2F4d3d19ab40dba0bfe96b88e4b4ca%2Fgettyimages-2258151.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2700x1519+0+141/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F64%2F46%2F4d3d19ab40dba0bfe96b88e4b4ca%2Fgettyimages-2258151.jpg" class="img" alt="Southern rap duo OutKast, consisting of André 3000 and Big Boi, are amongst the 14 artists being considered for the 2025 class of inductees into the Rock &amp;amp; Roll Hall of Fame." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Southern rap duo OutKast, consisting of André 3000 and Big Boi, are amongst the 14 artists being considered for the 2025 class of inductees into the Rock &amp; Roll Hall of Fame.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Kevin Winter/Getty Images/Getty Images North America                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;ol class="edTag"&gt;&lt;li&gt;The Rock &amp; Roll Hall of Fame &lt;a href="https://www.npr.org/2025/02/12/nx-s1-5293515/rock-roll-hall-of-fame-2025-nominees" target="_blank"&gt;announced the shortlist&lt;/a&gt; for its 2025 inductees today, which includes OutKast, Maná, Phish and Billy Idol.&lt;/li&gt;&lt;li&gt;When Melissa Barbanell's young son was hit by a pickup truck in 2010, the trained first responder felt frozen. A nearby jogger became her unsung hero when she &lt;a href="https://www.npr.org/2025/02/12/nx-s1-5288166/accident-boy-kindness-stranger-nurse" target="_blank"&gt;leaped in to help&lt;/a&gt;. Barbanell's son, now 21, recently graduated from his local community college.&lt;/li&gt;&lt;li&gt;In a strongly worded letter to U.S. Catholic bishops, Pope Francis &lt;a href="https://www.npr.org/2025/02/11/g-s1-48194/pope-rebukes-trump-over-migrant-deportations-and-refutes-vp-vances-theology" target="_blank"&gt;criticized the Trump administration's stance&lt;/a&gt; on migrants and refuted Vice President Vance's theology and remarks about how people should care for their family, communities and country before caring for others.&lt;/li&gt;&lt;/ol&gt;   &lt;p&gt;&lt;em&gt;This newsletter was edited by &lt;/em&gt;&lt;a href="https://www.npr.org/people/g-s1-2467/obed-manuel"target="_blank"   &gt;&lt;strong&gt;&lt;em&gt;Obed Manuel&lt;/em&gt;&lt;/strong&gt;&lt;/a&gt;&lt;strong&gt;&lt;em&gt;.&lt;/em&gt;&lt;/strong&gt;&lt;/p&gt; &lt;/div&gt;</description>
