.s3.amazonaws.com%2F1b%2Fc1%2F6c2220334670b9ea9c011bca9fda%2Fgettyimages-152052254.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+310/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1b%2Fc1%2F6c2220334670b9ea9c011bca9fda%2Fgettyimages-152052254.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+310/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1b%2Fc1%2F6c2220334670b9ea9c011bca9fda%2Fgettyimages-152052254.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+310/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1b%2Fc1%2F6c2220334670b9ea9c011bca9fda%2Fgettyimages-152052254.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+310/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1b%2Fc1%2F6c2220334670b9ea9c011bca9fda%2Fgettyimages-152052254.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+310/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1b%2Fc1%2F6c2220334670b9ea9c011bca9fda%2Fgettyimages-152052254.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+310/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1b%2Fc1%2F6c2220334670b9ea9c011bca9fda%2Fgettyimages-152052254.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+310/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F1b%2Fc1%2F6c2220334670b9ea9c011bca9fda%2Fgettyimages-152052254.jpg" class="img" alt="Actor Terence Stamp is pictured in 2012 in Toronto. Stamp has died at age 87." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Actor Terence Stamp is pictured in 2012 in Toronto. Stamp has died at age 87.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Sonia Recchia/Getty Images                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;ol class="edTag"&gt;&lt;li&gt;English actor Terence Stamp, best known for starring as the arch-villain in early &lt;em&gt;Superman&lt;/em&gt; films and for his title role in &lt;em&gt;Billy Budd&lt;/em&gt;, &lt;a href="https://www.npr.org/2025/08/18/nx-s1-5505466/actor-terence-stamp-dies" target="_blank"&gt;died yesterday at age 87&lt;/a&gt;.&lt;/li&gt;&lt;li&gt;Chimpanzee babies learn vocal and visual communication patterns from their mothers and maternal relatives, according to a new study in&lt;em&gt; PLOS Biology&lt;/em&gt;. The finding is believed to shed light on &lt;a href="https://www.npr.org/2025/08/16/nx-s1-5502642/chimp-moms-babies-human-language-communication-style" target="_blank"&gt;the way young humans learn&lt;/a&gt; from those close to them.&lt;/li&gt;&lt;li&gt;Electricity prices are &lt;a href="https://www.npr.org/2025/08/16/nx-s1-5502671/electricity-bill-high-inflation-ai" target="_blank"&gt;rising over twice as fast&lt;/a&gt; as overall inflation, which can be costly during the heat of summer when air conditioners work the hardest.&lt;/li&gt;&lt;/ol&gt;   &lt;p&gt;&lt;em&gt;This newsletter was edited by &lt;/em&gt;&lt;a href="https://www.npr.org/people/859721331/suzanne-nuyen"target="_blank"   &gt;&lt;strong&gt;&lt;em&gt;Suzanne Nuyen&lt;/em&gt;&lt;/strong&gt;&lt;/a&gt;&lt;strong&gt;&lt;em&gt;.&lt;/em&gt;&lt;/strong&gt;&lt;/p&gt; &lt;/div&gt;</description>
