=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F0c%2F6e8b52014b8abe1337a2d74d55da%2Fsunset-blvd-ny-dress-one-3263-enhanced-nr-pjzedit-v002-1-1.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+112/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F0c%2F6e8b52014b8abe1337a2d74d55da%2Fsunset-blvd-ny-dress-one-3263-enhanced-nr-pjzedit-v002-1-1.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+112/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F0c%2F6e8b52014b8abe1337a2d74d55da%2Fsunset-blvd-ny-dress-one-3263-enhanced-nr-pjzedit-v002-1-1.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+112/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F0c%2F6e8b52014b8abe1337a2d74d55da%2Fsunset-blvd-ny-dress-one-3263-enhanced-nr-pjzedit-v002-1-1.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+112/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F0c%2F6e8b52014b8abe1337a2d74d55da%2Fsunset-blvd-ny-dress-one-3263-enhanced-nr-pjzedit-v002-1-1.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+112/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F0c%2F6e8b52014b8abe1337a2d74d55da%2Fsunset-blvd-ny-dress-one-3263-enhanced-nr-pjzedit-v002-1-1.jpg" class="img" alt="Nicole Scherzinger as Norma Desmond in Sunset Blvd." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Nicole Scherzinger as Norma Desmond in &lt;em&gt;Sunset Blvd&lt;/em&gt;.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Marc Brenner                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;ol class="edTag"&gt;&lt;li&gt;This year's &lt;a href="https://www.npr.org/2025/05/01/nx-s1-5381181/tony-award-nominations-2025-scherzinger-clooney-sink-snook" target="_blank"&gt;Tony nominations are out&lt;/a&gt;. No Broadway show swept the categories, showing how strong a season it was.&lt;/li&gt;&lt;li&gt;A UFO watch tower in San Luis Valley, Colo., will &lt;a href="https://www.cpr.org/2025/04/24/ufo-watchtower-celebrates-25-years/" target="_blank"&gt;celebrate 25 years this month&lt;/a&gt;. What started as a joke now draws around 10,000 visitors a year. (via &lt;a href="https://www.cpr.org/" target="_blank"&gt;CPR&lt;/a&gt;)&lt;/li&gt;&lt;li&gt;Writer Canisia Lubrin, known for her poetry, &lt;a href="https://www.npr.org/2025/05/01/nx-s1-5377339/canisia-lubrin-code-noir-carol-shields-book-prize" target="_blank"&gt;won this year's&lt;/a&gt; Carol Shields Prize for Fiction with her debut short story collection&lt;em&gt; Code Noir&lt;/em&gt;.&lt;/li&gt;&lt;/ol&gt;   &lt;p&gt;&lt;em&gt;This newsletter was edited by &lt;/em&gt;&lt;a href="https://www.npr.org/people/859721331/suzanne-nuyen"target="_blank"   &gt;&lt;strong&gt;&lt;em&gt;Suzanne Nuyen&lt;/em&gt;&lt;/strong&gt;&lt;/a&gt;&lt;em&gt;.&lt;/em&gt;&lt;/p&gt; &lt;/div&gt;</description>
