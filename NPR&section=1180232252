      <description>&lt;div id="storytext" class="storytext storylocation linkLocation"&gt;       &lt;div id="resg-s1-75474" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 6000;         --source-height: 3376;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x3376+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F9e%2Fea%2F4a2d22204fe69ba02de20e536009%2Fgettyimages-2179549391.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x3376+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F9e%2Fea%2F4a2d22204fe69ba02de20e536009%2Fgettyimages-2179549391.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x3376+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F9e%2Fea%2F4a2d22204fe69ba02de20e536009%2Fgettyimages-2179549391.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x3376+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F9e%2Fea%2F4a2d22204fe69ba02de20e536009%2Fgettyimages-2179549391.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x3376+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F9e%2Fea%2F4a2d22204fe69ba02de20e536009%2Fgettyimages-2179549391.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x3376+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F9e%2Fea%2F4a2d22204fe69ba02de20e536009%2Fgettyimages-2179549391.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6000x3376+0+0/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F9e%2Fea%2F4a2d22204fe69ba02de20e536009%2