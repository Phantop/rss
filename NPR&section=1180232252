spot.s3.amazonaws.com%2F27%2Fad%2F9468750e4ca4a6d502bc69615b19%2F20230725-cea5206.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5835x3282+0+608/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F27%2Fad%2F9468750e4ca4a6d502bc69615b19%2F20230725-cea5206.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5835x3282+0+608/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F27%2Fad%2F9468750e4ca4a6d502bc69615b19%2F20230725-cea5206.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5835x3282+0+608/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F27%2Fad%2F9468750e4ca4a6d502bc69615b19%2F20230725-cea5206.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5835x3282+0+608/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F27%2Fad%2F9468750e4ca4a6d502bc69615b19%2F20230725-cea5206.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5835x3282+0+608/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F27%2Fad%2F9468750e4ca4a6d502bc69615b19%2F20230725-cea5206.jpg" class="img" alt="Born Ruffians" loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Born Ruffians                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Courtesy of the artist                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;Born Ruffians frontman Luke Lalonde drew inspiration for the band's latest album, &lt;em&gt;Beauty's Pride&lt;/em&gt;, from a trip to India. In fact, he couldn't get the phrase out of his head after he borrowed a purple children's bike adorned with the phrase. The album was written largely while Lalonde was preparing for the birth of his first child. His little one even made an adorable debut on one of the tracks. Now, nearly two decades into their career, the Toronto indie rock band continues to evolve musically. Lalonde joins &lt;em&gt;World Cafe &lt;/em&gt;to discuss the making of the new album and &lt;a href="https://one.npr.org/?sharedMediaId=nx-s1-5487698:g-s1-82107" target="_blank"&gt;perform some of the new songs&lt;/a&gt;.&lt;/p&gt;   &lt;h3 class="edTag"&gt;Living better &lt;/h3&gt;   &lt;div id="resg-s1-81852" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 2121;         --source-height: 1193;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2121x1193+0+37/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F43%2Fe9%2Fc59761e54a70bad7dc8f48ace7bf%2Fgettyimages-1568586862.jpg" class="img" alt="Birth control pills pack. Female contraception concept for sex and reproduction, population control, feminism, or women&amp;#039;s rights to choose. These contraceptive pills are prescription medicine that contain female hormones like estrogen and progestin to prevent pregnancy during family planning choice or to control PMS / PMDD medical condition during mensuration. Conceptual symbol of human fertility concept. Full unused, monthly pill pack on pink background, no people. Part of a series." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Birth control pills pack.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Jena Ardell/Moment RF/Getty Images                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;em&gt;Living Better is a &lt;/em&gt;&lt;a href="https://www.npr.org/series/1176326550/living-better" target="_blank"&gt;&lt;em&gt;special series&lt;/em&gt;&lt;/a&gt;&lt;em&gt; about what it takes to stay healthy in America.&lt;/em&gt;&lt;/p&gt;   &lt;p&gt;TikTok posts are making claims that hormonal birth control can cause a nearly unlimited list of ailments, including depression, irreversible infertility, balding and a decreased libido. A growing number of influencers are advocating for people to avoid birth control and track fertility cycles naturally or with apps. Researchers and doctors discuss &lt;a href="https://www.npr.org/2025/08/11/nx-s1-5494736/hormonal-birth-control-side-effects" target="_blank"&gt;how birth control got such a bad reputation&lt;/a&gt;. &lt;br&gt;&lt;/p&gt;   &lt;ul class="edTag"&gt;&lt;li&gt;💊 A study found that TikTok videos on contraception had "poor reliability and quality." Only 10% were created by medical professionals.&lt;/li&gt;&lt;li&gt;💊 More common side effects of hormonal birth control include headaches, mood changes and breast tenderness. Contraceptives are safe for most people, but clinicians stress that people should evaluate their individual risks with a doctor.&lt;/li&gt;&lt;li&gt;💊 Concerns about birth control are often mixed with a significant issue: Women frequently feel overlooked in medical environments, says Emily Pfender, a researcher at the University of Pennsylvania.&lt;/li&gt;&lt;/ul&gt;   &lt;h3 class="edTag"&gt;3 things to know before you go&lt;/h3&gt;   &lt;div id="resg-s1-82015" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 1920;         --source-height: 1080;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1080+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe1%2F48%2F46408ab343cd8fc07de3b3bfb26d%2Ffarflungpostcard-paris.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1080+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe1%2F48%2F46408ab343cd8fc07de3b3bfb26d%2Ffarflungpostcard-paris.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1080+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe1%2F48%2F46408ab343cd8fc07de3b3bfb26d%2Ffarflungpostcard-paris.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1080+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe1%2F48%2F46408ab343cd8fc07de3b3bfb26d%2Ffarflungpostcard-paris.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1080+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe1%2F48%2F46408ab343cd8fc07de3b3bfb26d%2Ffarflungpostcard