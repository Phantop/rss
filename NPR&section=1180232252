A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F35%2F6a%2F2d372b664e24a2eaa3113231fb3d%2Fdf-06276-r-1000x562-thumbnail-wide-01208f70aba6572df63aba610d27093061af9fae.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/599x337+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F35%2F6a%2F2d372b664e24a2eaa3113231fb3d%2Fdf-06276-r-1000x562-thumbnail-wide-01208f70aba6572df63aba610d27093061af9fae.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/599x337+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F35%2F6a%2F2d372b664e24a2eaa3113231fb3d%2Fdf-06276-r-1000x562-thumbnail-wide-01208f70aba6572df63aba610d27093061af9fae.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/599x337+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F35%2F6a%2F2d372b664e24a2eaa3113231fb3d%2Fdf-06276-r-1000x562-thumbnail-wide-01208f70aba6572df63aba610d27093061af9fae.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/599x337+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F35%2F6a%2F2d372b664e24a2eaa3113231fb3d%2Fdf-06276-r-1000x562-thumbnail-wide-01208f70aba6572df63aba610d27093061af9fae.jpg" class="img" alt="Keke Palmer and SZA in Tri-Star Pictures ONE OF THEM DAYS (Photo by Anne Marie Fox)" loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Keke Palmer and SZA in Tri-Star Pictures ONE OF THEM DAYS (Photo by Anne Marie Fox)                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Anne Marie Fox/Anne Marie Fox                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;Check out what &lt;/strong&gt;&lt;a href="https://www.npr.org/sections/culture/" target="_blank"&gt;&lt;strong&gt;NPR&lt;/strong&gt;&lt;/a&gt;&lt;strong&gt; is watching, reading and listening to this weekend:&lt;/strong&gt;&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🍿 Movies:&lt;/strong&gt; &lt;a href="https://www.npr.org/2025/01/22/1226038398/one-of-them-days-turns-keke-palmer-and-sza-loose" target="_blank"&gt;&lt;em&gt;One of Them Days&lt;/em&gt;&lt;/a&gt;&lt;em&gt; &lt;/em&gt;is a comedy about two best friends, played by Keke Palmer and SZA, who endure a wild series of misadventures as they try to make rent over an eventful day.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;📺 TV:&lt;/strong&gt; &lt;a href="https://www.npr.org/2025/01/17/nx-s1-5252906/severance-season-2-review" target="_blank"&gt;&lt;em&gt;Severance&lt;/em&gt;&lt;/a&gt;'s second season is now streaming on Apple TV+, and it's even more gloriously weird and deftly assembled than the first one.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;📚 Books:&lt;/strong&gt; There is still time to catch up on some perspective-shifting titles from 2024 before throwing yourself into this year's new reads. &lt;a href="https://www.npr.org/2025/01/10/nx-s1-5196704/best-nonfiction" target="_blank"&gt;Check out these 12 books&lt;/a&gt; exploring the art world, life after death, life as a nun and more.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🎵 Music:&lt;/strong&gt; Tina Turner's lost song "Hot For You Baby" was re-introduced to the world yesterday morning. &lt;a href="https://www.npr.org/2025/01/23/nx-s1-5272693/tina-turner-lost-song" target="_blank"&gt;Check it out here&lt;/a&gt;.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;❓ Quiz:&lt;/strong&gt; Well… I didn't do badly, but I could have done better. Please take some time to &lt;a href="https://www.npr.org/2025/01/24/g-s1-44308/inauguration-trump-oscars-tiktok-erivo-grande" target="_blank"&gt;redeem me with your score&lt;/a&gt;.&lt;br&gt;&lt;/p&gt;   &lt;h3 class="edTag"&gt;3 things to know before you go&lt;/h3&gt;   &lt;div id="resg-s1-44079" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 3024;         --source-height: 1701;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fe5%2F8a%2F4d0e200b4f47b56b38898b200c5e%2Fstick2.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3024x1701+0+1952/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.