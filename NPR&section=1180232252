1d9e494628%2F186071607-20160827-13-23-39.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4160x2340+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F6f%2Fdc%2F19b075174044b2bf341d9e494628%2F186071607-20160827-13-23-39.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4160x2340+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F6f%2Fdc%2F19b075174044b2bf341d9e494628%2F186071607-20160827-13-23-39.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4160x2340+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F6f%2Fdc%2F19b075174044b2bf341d9e494628%2F186071607-20160827-13-23-39.jpg" class="img" alt="A little girl holds her father&amp;#039;s hand as he helps carry a casket at a funeral." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 A little girl holds her father's hand as he helps carry a casket at a funeral.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Gayle Stratford                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;Gayle Stratford captured the moment when her sweet, spontaneous niece joined her dad and uncles at her grandma's funeral. The men were pallbearers at the ceremony. Stratford, 69, said no one stopped the little girl because the moment was sacred and precious. "To have my young niece participate in my mother's funeral in that way was so very touching to me," she said.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;Stratford's tip:&lt;/strong&gt; "Be aware of details in everyday life."&lt;/p&gt;   &lt;h3 class="edTag"&gt;Moments of love&lt;/h3&gt;   &lt;div id="resg-s1-82949" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 5304;         --source-height: 2984;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5304x2984+0+2784/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc2%2F91%2Fbf32cd434ab2b271a2553d79368f%2F186071607-fullres-dsc3295.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5304x2984+0+2784/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc2%2F91%2Fbf32cd434ab2b271a2553d79368f%2F186071607-fullres-dsc3295.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5304x2984+0+2784/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc2%2F91%2Fbf32cd434ab2b271a2553d79368f%2F186071607-fullres-dsc3295.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5304x2984+0+2784/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc2%2F91%2Fbf32cd434ab2b271a2553d79368f%2F186071607-fullres-dsc3295.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5304x2984+0+2784/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc2%2F91%2Fbf32cd434ab2b271a2553d79368f%2F186071607-fullres-dsc3295.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5304x2984+0+2784/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc2%2F91%2Fbf32cd43