69e67%2Fthumbnail-david-kadouch004.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1280+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc5%2Fac%2Fe95823964285aacfc3458ea69e67%2Fthumbnail-david-kadouch004.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1280+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc5%2Fac%2Fe95823964285aacfc3458ea69e67%2Fthumbnail-david-kadouch004.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1280+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc5%2Fac%2Fe95823964285aacfc3458ea69e67%2Fthumbnail-david-kadouch004.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1280+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc5%2Fac%2Fe95823964285aacfc3458ea69e67%2Fthumbnail-david-kadouch004.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1280+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc5%2Fac%2Fe95823964285aacfc3458ea69e67%2Fthumbnail-david-kadouch004.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1280+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc5%2Fac%2Fe95823964285aacfc3458ea69e67%2Fthumbnail-david-kadouch004.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1280+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc5%2Fac%2Fe95823964285aacfc3458ea69e67%2Fthumbnail-david-kadouch004.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1920x1280+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fc5%2Fac%2Fe95823964285aacfc3458ea69e67%2Fthumbnail-david-kadouch004.jpg" class="img" alt="In his new album, Amours Interdites, French pianist David Kadouch highlights music by gay composers whose concealed their sexuality because it wasn&amp;#039;t accepted in the late 19th and early 20th centuries." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 In his new album, &lt;em&gt;Amours Interdites&lt;/em&gt;, French pianist David Kadouch highlights music by gay composers whose concealed their sexuality because it wasn't accepted in the late 19th and early 20th centuries.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Marco Borggreve                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;In&lt;em&gt; Amours Interdites&lt;/em&gt; (Forbidden Love), French pianist David Kadouch explores the works of gay composers&lt;/strong&gt; from the late 19th and early 20th centuries. Kadouch told &lt;em&gt;Morning Edition &lt;/em&gt;host Michel Martin that he wanted to tell the stories of people who were out in their letters and how sometimes in their music they tried to tell their secret. Classical music became a place of refuge, especially in Paris at the beginning of the 20th century, where it was not forbidden by law, but still frowned upon. &lt;br&gt;&lt;/p&gt;   &lt;ul class="edTag"&gt;&lt;li&gt;🎧 &lt;strong&gt;Listen to &lt;/strong&gt;&lt;a href="https://one.npr.org/?sharedMediaId=nx-s1-5220330:nx-s1-5332883-1" target="_blank"&gt;snippets from the album&lt;/a&gt; and read more about &lt;a href="https://www.npr.org/2025/01/24/nx-s1-5220330/french-pianist-david-kadouch-forbidden-love-new-album" target="_blank"&gt;how he views the work&lt;/a&gt;.&lt;/li&gt;&lt;/ul&gt;   &lt;h3 class="edTag"&gt;Life advice&lt;/h3&gt;   &lt;div id="resg-s1-44468" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 1379;         --source-height: 776;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1379x776+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff2%2F4e%2F9d5332ce4bbaa30d7df46209d9de%2Fpromo-image-cardio.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1379x776+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff2%2F4e%2F9d5332ce4bbaa30d7df46209d9de%2Fpromo-image-cardio.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1379x776+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff2%2F4e%2F9d5332ce4bbaa30d7df46209d9de%2Fpromo-image-cardio.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1379x776+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff2%2F4e%2F9d5332ce4bbaa30d7df46209d9de%2Fpromo-image-cardio.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1379x776+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff2%2F4e%2F9d5332ce4bbaa30d7df46209d9de%2Fpromo-image-cardio.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1379x776+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Ff2%2F4e%2F9d5332ce4bbaa30d