t/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F04%2F63%2F6d2139ca411fb4f3e627d07c27de%2Fgettyimages-2188905178.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5537x3115+0+288/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F04%2F63%2F6d2139ca411fb4f3e627d07c27de%2Fgettyimages-2188905178.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5537x3115+0+288/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F04%2F63%2F6d2139ca411fb4f3e627d07c27de%2Fgettyimages-2188905178.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5537x3115+0+288/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F04%2F63%2F6d2139ca411fb4f3e627d07c27de%2Fgettyimages-2188905178.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5537x3115+0+288/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F04%2F63%2F6d2139ca411fb4f3e627d07c27de%2Fgettyimages-2188905178.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5537x3115+0+288/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F04%2F63%2F6d2139ca411fb4f3e627d07c27de%2Fgettyimages-2188905178.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5537x3115+0+288/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F04%2F63%2F6d2139ca411fb4f3e627d07c27de%2Fgettyimages-2188905178.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5537x3115+0+288/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F04%2F63%2F6d2139ca411fb4f3e627d07c27de%2Fgettyimages-2188905178.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5537x3115+0+288/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F04%2F63%2F6d2139ca411fb4f3e627d07c27de%2Fgettyimages-2188905178.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5537x3115+0+288/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F04%2F63%2F6d2139ca411fb4f3e627d07c27de%2Fgettyimages-2188905178.jpg" class="img" alt="India&amp;#039;s grandmaster Gukesh Dommaraju reacts after winning against China&amp;#039;s chess grandmaster Ding Liren in game 14 of the 2024 FIDE World Championship in Singapore on Thursday." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 India's grandmaster Gukesh Dommaraju reacts after winning against China's chess grandmaster Ding Liren in game 14 of the 2024 FIDE World Championship in Singapore on Thursday.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Simon Lim/AFP via Getty Images                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;ol class="edTag"&gt;&lt;li&gt;&lt;strong&gt;Gukesh Dommaraju has become the new world chess champion.&lt;/strong&gt; The 18-year-old chess prodigy from India is now the &lt;a href="https://www.npr.org/2024/12/12/nx-s1-5227047/chess-gukesh-dommaraju-youngest-world-champion"&gt;youngest world champion of all time&lt;/a&gt;.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;An American man who identified himself as Pete Travis Timmerman was found wandering the Syrian capital &lt;/strong&gt;of Damascus yesterday. He was &lt;a href="https://www.npr.org/2024/12/12/nx-s1-5226745/missing-american-travis-timmerman-found-wandering-barefoot-outside-damascus"&gt;last seen in Budapest&lt;/a&gt;, Hungary, in June.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Stanley is recalling about 2.6 million of its travel mugs&lt;/strong&gt; due to an issue with the lids. The company is &lt;a href="https://www.npr.org/2024/12/13/nx-s1-5227763/stanley-mugs-cup-recall"&gt;offering free replacement lids&lt;/a&gt;.&lt;/li&gt;&lt;/ol&gt;   &lt;p&gt;&lt;em&gt;This newsletter was edited by &lt;/em&gt;&lt;a href="https://www.npr.org/people/859721331/suzanne-nuyen"&gt;&lt;em&gt;Suzanne Nuyen&lt;/em&gt;&lt;/a&gt;&lt;em&gt;.&lt;/em&gt;&lt;/p&gt; &lt;/div&gt;</description>
