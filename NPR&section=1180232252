+0+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F86%2Fd0%2Ffd8eb3c04d7a858d551ec1f1344a%2Fpair.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/819x461+0+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F86%2Fd0%2Ffd8eb3c04d7a858d551ec1f1344a%2Fpair.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/819x461+0+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F86%2Fd0%2Ffd8eb3c04d7a858d551ec1f1344a%2Fpair.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/819x461+0+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F86%2Fd0%2Ffd8eb3c04d7a858d551ec1f1344a%2Fpair.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/819x461+0+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F86%2Fd0%2Ffd8eb3c04d7a858d551ec1f1344a%2Fpair.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/819x461+0+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F86%2Fd0%2Ffd8eb3c04d7a858d551ec1f1344a%2Fpair.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/819x461+0+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F86%2Fd0%2Ffd8eb3c04d7a858d551ec1f1344a%2Fpair.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/819x461+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F86%2Fd0%2Ffd8eb3c04d7a858d551ec1f1344a%2Fpair.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/819x461+0+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F86%2Fd0%2Ffd8eb3c04d7a858d551ec1f1344a%2Fpair.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/819x461+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F86%2Fd0%2Ffd8eb3c04d7a858d551ec1f1344a%2Fpair.jpg" class="img" alt="Malcolm Campbell (left) and Don Lawson from their yearbooks in the 1980s." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Malcolm Campbell (left) and Don Lawson from their yearbooks in the 1980s.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Malcolm Campbell                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;ol class="edTag"&gt;&lt;li&gt;&lt;strong&gt;Malcolm Campbell has a PhD in molecular biology and spent three decades teaching.&lt;/strong&gt; He credits his high school civics teacher and unsung hero Don Lawson for helping him &lt;a href="https://www.npr.org/2024/10/21/nx-s1-5159715/professor-kindness-good-news-high-school-teacher"&gt;understand the true value of education&lt;/a&gt;.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;The Consumer Financial Protection Bureau has fined Apple and Goldman Sachs $89 million&lt;/strong&gt; for allegedly harming hundreds of thousands of Apple cardholders by &lt;a href="https://www.npr.org/2024/10/23/g-s1-29566/apple-goldman-sachs-fine-apple-card-cfpb"&gt;mishandling disputed transactions&lt;/a&gt; and using deceptive marketing practices.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Boeing machinists voted to reject the company’s latest contract proposal &lt;/strong&gt;yesterday, &lt;a href="https://www.npr.org/2024/10/23/g-s1-29638/boeing-machinists-reject-contract-strike"&gt;prolonging a grueling strike&lt;/a&gt; that has already lasted more than 40 days.&lt;/li&gt;&lt;/ol&gt;       &lt;p&gt;&lt;em&gt;This newsletter was edited by &lt;/em&gt;&lt;a href="https://www.npr.org/people/859721331/suzanne-nuyen"&gt;&lt;em&gt;Suzanne Nuyen&lt;/em&gt;&lt;/a&gt;&lt;em&gt;.&lt;/em&gt;&lt;/p&gt; &lt;/div&gt;</description>
