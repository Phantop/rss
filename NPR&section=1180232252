960x540+0+237/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F7f%2F76127e2c4f1099488892c85ddf61%2Findependent-lens-signature-image.jpeg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/960x540+0+237/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F7f%2F76127e2c4f1099488892c85ddf61%2Findependent-lens-signature-image.jpeg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/960x540+0+237/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F7f%2F76127e2c4f1099488892c85ddf61%2Findependent-lens-signature-image.jpeg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/960x540+0+237/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F7f%2F76127e2c4f1099488892c85ddf61%2Findependent-lens-signature-image.jpeg" class="img" alt="Special collections at the Boston Public Library. CreditLucie Faulknor / PBS" loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Special collections at the Boston Public Library.&lt;br&gt;                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Lucie Faulknor/PBS                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;Check out what &lt;/strong&gt;&lt;a href="https://www.npr.org/sections/culture/" target="_blank"&gt;&lt;b&gt;NPR&lt;/b&gt;&lt;/a&gt;&lt;strong&gt; is watching, reading and listening to this weekend:&lt;/strong&gt;&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🍿 Movies:&lt;/strong&gt; &lt;a href="https://www.npr.org/2025/04/29/nx-s1-5380803/free-for-all-library-documentary-pbs" target="_blank"&gt;&lt;i&gt;Free for All: The Public Library&lt;/i&gt;&lt;/a&gt;, a new PBS film, examines the value of libraries in the past and makes a compelling case for the importance of the American public library system today.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;📺 TV:&lt;/strong&gt; &lt;a href="https://one.npr.org/?sharedMediaId=1248091509:1269214339" target="_blank"&gt;&lt;i&gt;Étoile&lt;/i&gt;&lt;/a&gt; revolves around two prestigious ballet companies, one in New York and the other in Paris, that are dealing with plummeting ticket sales. To help save the art form, the companies decide to swap their most valuable members for a season.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;📚 Books: &lt;/strong&gt;&lt;a href="https://www.npr.org/2025/04/29/nx-s1-5333674/new-books" target="_blank"&gt;&lt;i&gt;The Fate of the Day&lt;/i&gt;&lt;/a&gt;, the second installment in historian Rick Atkinson's planned trilogy on the American Revolution, hit shelves this week. Plus, a graphic memoir, short fiction, and "the secret life" of a cemetery.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🎵 Music:&lt;/strong&gt; Many artists, including Aly &amp; Aj, Pink Floyd, Car Seat Headrest, and Eric Church, released new music at midnight. Catch up on your favorite musicians and discover new ones with &lt;a href="https://www.npr.org/sections/all-songs-considered/2025/05/02/g-s1-63781/new-music-friday-car-seat-headrest-pup-lucius" target="_blank"&gt;this playlist&lt;/a&gt; of the best songs from each album.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;❓ Quiz: &lt;/strong&gt;I sadly didn't do great this week. This test truly bested me. However, I believe in YOU and &lt;a href="https://www.npr.org/2025/05/02/g-s1-63177/kardashian-clooney-titanic-minecraft-columbus-day" target="_blank"&gt;your ability to ace it&lt;/a&gt;.&lt;/p&gt;   &lt;h3 class="edTag"&gt;3 things to know before you go&lt;/h3&gt;   &lt;div id="resg-s1-63730" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 2000;         --source-height: 1124;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+112/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F0c%2F6e8b52014b8abe1337a2d74d55da%2Fsunset-blvd-ny-dress-one-3263-enhanced-nr-pjzedit-v002-1-1.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+112/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F0c%2F6e8b52014b8abe1337a2d74d55da%2Fsunset-blvd-ny-dress-one-3263-enhanced-nr-pjzedit-v002-1-1.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+112/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F0c%2F6e8b52014b8abe1337a2d74d55da%2Fsunset-blvd-ny-dress-one-3263-enhanced-nr-pjzedit-v002-1-1.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+112/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F0c%2F6e8b52014b8abe1337a2d74d55da%2Fsunset-blvd-ny-dress-one-3263-enhanced-nr-pjzedit-v002-1-1.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+112/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F0c%2F6e8b52014b8abe1337a2d74d55da%2Fsunset-blvd-ny-dress-one-3263-enhanced-nr-pjzedit-v002-1-1.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+112/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fcc%2F0c%2F6e8