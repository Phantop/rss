peg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F54%2F4e%2F04430fa541ccbe447e44ecd315a1%2Fstitching-1.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/7394x4159+0+386/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F54%2F4e%2F04430fa541ccbe447e44ecd315a1%2Fstitching-1.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/7394x4159+0+386/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F54%2F4e%2F04430fa541ccbe447e44ecd315a1%2Fstitching-1.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/7394x4159+0+386/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F54%2F4e%2F04430fa541ccbe447e44ecd315a1%2Fstitching-1.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/7394x4159+0+386/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F54%2F4e%2F04430fa541ccbe447e44ecd315a1%2Fstitching-1.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/7394x4159+0+386/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F54%2F4e%2F04430fa541ccbe447e44ecd315a1%2Fstitching-1.jpg" class="img" alt="Margarita Rojas Mena, in Mojaudó, stitched up the photograph of the community school, wounded by bullets from an armed confrontation." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Margarita Rojas Mena, in Mojaudó, stitched up the photograph of the community school, wounded by bullets from an armed confrontation.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Fernanda Pineda/MSF                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;Doctors Without Borders launched a two-year project in 2022 aimed at healing psychic wounds in the remote area of Alto Baudóin western Colombia. The region has experienced years of violence due to conflicts between armed rebel groups and criminal organizations. The project involves tearing up photographs of loved ones and homes and then sewing them back together, an act that serves as a metaphor for healing. The goal is to create rituals that help individuals manage anxiety, depression and other mental health issues. Colombian photographer Fernanda Pineda documented the initiative in her photo series &lt;em&gt;Riografias del Baudó&lt;/em&gt;. Take a peek at the photo collection &lt;a href="https://www.npr.org/sections/goats-and-soda/2025/06/19/g-s1-73120/photos-herbs-rituals-colombia-doctors-without-borders-photoville" target="_blank"&gt;here&lt;/a&gt;.&lt;/p&gt;   &lt;h3 class="edTag"&gt;Weekend picks&lt;/h3&gt;   &lt;div id="resg-s1-72997" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 3840;         --source-height: 2160;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3840x2160+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F7e%2F45%2F503a372443f99f60dbfa102ad6a5%2Fbrucelosttracks1.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3840x2160+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F7e%2F45%2F503a372443f99f6