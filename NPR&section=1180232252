16d6a661%2Fndlovu-youth-choir-bohemian-rhapsody-2025-master-4k-2-00811.png 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3840x2160+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F51%2Fed%2Fb21173f54f058038502b16d6a661%2Fndlovu-youth-choir-bohemian-rhapsody-2025-master-4k-2-00811.png" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/png" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3840x2160+0+0/resize/1100/quality/50/format/png/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F51%2Fed%2Fb21173f54f058038502b16d6a661%2Fndlovu-youth-choir-bohemian-rhapsody-2025-master-4k-2-00811.png" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3840x2160+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F51%2Fed%2Fb21173f54f058038502b16d6a661%2Fndlovu-youth-choir-bohemian-rhapsody-2025-master-4k-2-00811.png" class="img" alt="Ndlovu Youth Choir - Bohemian Rhapsody" loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Ndlovu Youth Choir - Bohemian Rhapsody                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Ndlovu Youth Choir                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;The Ndlovu Youth Choir has released an exciting new project: a Zulu-language version of Queen's "Bohemian Rhapsody." The choir originated in South Africa's rural Limpopo province and gained international fame on &lt;em&gt;America's Got Talent&lt;/em&gt; in 2019. The project marks the first time Queen has authorized a translation of the iconic rock song. Coinciding with the song's 50th anniversary, the new version incorporates African musical traditions, blending styles from township music like isicathamiya with the Congolese swing of kwassa kwassa. Listen to a &lt;a href="https://one.npr.org/?sharedMediaId=nx-s1-5521906:nx-s1-9433332" target="_blank"&gt;snippet of the Zulu-language version of the song&lt;/a&gt;, or &lt;a href="https://www.npr.org/2025/08/30/nx-s1-5521906/queens-bohemianrhapsody-zulu-ndlovu-voice-choir" target="_blank"&gt;read more about the project&lt;/a&gt;.&lt;/p&gt;       &lt;h3 class="edTag"&gt;3 things to know before you go&lt;/h3&gt;   &lt;div id="resg-s1-86632" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 2648;         --source-height: 1489;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2648x1489+178+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F11%2F2f%2F41b92fd1414480589220645d0f34%2Fap25224730115506.jpg" class="img" alt="Malle (right) takes over the reins of American Vogue from legendary editor Anna Wintour (left)." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Malle (right) takes over the reins of American &lt;em&gt;Vogue &lt;/em&gt;from legendary editor Anna Wintour (left).                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Evan Agostini/Invision/AP                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;ol class="edTag"&gt;&lt;li&gt;Chloe Malle was announced yesterday as the &lt;a href="https://www.npr.org/2025/09/02/nx-s1-5525663/vogue-chloe-malle-anna-wintour" target="_blank"&gt;new head of editorial content for&lt;/a&gt; American &lt;em&gt;Vogue&lt;/em&gt;. She moves into the role two months after Anna Wintour decided to step away from managing &lt;em&gt;Vogue&lt;/em&gt;'s daily editorial operations.&lt;/li&gt;&lt;li&gt;Kraft Heinz is &lt;a href="https://www.npr.org/2025/09/02/nx-s1-5464951/kraft-heinz-split-breakup" target="_blank"&gt;splitting into two separate companies&lt;/a&gt;. The breakup comes a decade after its messy mega-merger, arranged by billionaire investor Warren Buffett.&lt;/li&gt;&lt;li&gt;Social media influencer Ed People is asking people all over the world to &lt;a href="https://www.npr.org/2025/08/27/nx-s1-5475213/ed-people-dance-world-social-media" target="_blank"&gt;show off their favorite dance moves&lt;/a&gt;. He says the project's goal is to bring joy, build bridges and showcase diverse cultures worldwide.&lt;/li&gt;&lt;/ol&gt;   &lt;p&gt;&lt;em&gt;This newsletter was edited by &lt;/em&gt;&lt;a href="https://www.npr.org/people/859721331/suzanne-nuyen"target="_blank"   &gt;&lt;strong&gt;&lt;em&gt;Suzanne Nuyen&lt;/em&gt;&lt;/strong&gt;&lt;/a&gt;&lt;strong&gt;&lt;em&gt;.&lt;/em&gt;&lt;/strong&gt;&lt;/p&gt; &lt;/div&gt;</description>
