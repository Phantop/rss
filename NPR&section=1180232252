mazonaws.com%2F15%2Ff9%2Fbf01470b4132bfff0861191694ff%2Funtitled-design.png 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1100x619+0+0/resize/600/quality/85/format/png/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F15%2Ff9%2Fbf01470b4132bfff0861191694ff%2Funtitled-design.png 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1100x619+0+0/resize/800/quality/85/format/png/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F15%2Ff9%2Fbf01470b4132bfff0861191694ff%2Funtitled-design.png 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1100x619+0+0/resize/900/quality/85/format/png/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F15%2Ff9%2Fbf01470b4132bfff0861191694ff%2Funtitled-design.png 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1100x619+0+0/resize/1200/quality/85/format/png/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F15%2Ff9%2Fbf01470b4132bfff0861191694ff%2Funtitled-design.png 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1100x619+0+0/resize/1600/quality/85/format/png/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F15%2Ff9%2Fbf01470b4132bfff0861191694ff%2Funtitled-design.png 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1100x619+0+0/resize/1800/quality/85/format/png/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F15%2Ff9%2Fbf01470b4132bfff0861191694ff%2Funtitled-design.png 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1100x619+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F15%2Ff9%2Fbf01470b4132bfff0861191694ff%2Funtitled-design.png" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/png" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1100x619+0+0/resize/1100/quality/50/format/png/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F15%2Ff9%2Fbf01470b4132bfff0861191694ff%2Funtitled-design.png" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1100x619+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F15%2Ff9%2Fbf01470b4132bfff0861191694ff%2Funtitled-design.png" class="img" alt="Hitomi Demers, Marissa Díaz, Emily Jordan and Elisa Antrom" loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Hitomi Demers, Marissa Díaz, Emily Jordan and Elisa Antrom                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Compiled by NPR                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;Singles are making the time-old tradition of holiday cards their own. &lt;/strong&gt;When you get a holiday card in the mailbox, it usually features a family or a couple. But more singles are crafting creative card designs that feature just them to celebrate the holidays. NPR's Claire Murashima received her first card from a single friend and was intrigued to hear from other singles who are picking up the tradition. Thousands of people sent in emails sharing their stories. Listen to them explain &lt;a href="https://one.npr.org/?sharedMediaId=nx-s1-5231604:nx-s1-5298101-1" target="_blank"&gt;why they are participating in this tradition&lt;/a&gt; and see &lt;a href="https://www.npr.org/2024/12/19/nx-s1-5231604/single-women-christmas-cards-holidays" target="_blank"&gt;some of the holiday cards they've sent to friends and family&lt;/a&gt;.&lt;br&gt;&lt;/p&gt;   &lt;h3 class="edTag"&gt;Deep dive&lt;/h3&gt;   &lt;div id="resg-s1-38535" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 3936;         --source-height: 2624;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3936x2624+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F18%2F0c%2F36e84485400c934a60d1dee937a3%2Fgettyimages-1689515342.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3936x2624+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F18%2F0c%2F36e84485400c934a60d1dee937a3%2Fgettyimages-1689515342.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3936x2624+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F18%2F0c%2F36e84485400c934a60d1dee937a3%2Fgettyimages-1689515342.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3936x2624+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F18%2F0c%2F36e84485400c934a60d1dee937a3%2Fgettyimages-1689515342.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3936x2624+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F18%2F0c%2F36e84485400c934a60d1dee937a3%2Fgettyimages-1689515342.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3936x2624+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F18%2F0c%2F36e84485400c934a60d1dee937a3%2Fgettyimages-1689515342.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3936x2624+0+0/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F18%2F0c%2F36e84485400c934a60d1dee937a3%2F