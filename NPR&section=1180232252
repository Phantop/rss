lass="img" type="image/webp" /&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3051x1716+265+0/resize/400/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F0f%2Fb0%2Fc4e17dcc4e6b8cc21146046a9da1%2Feah4020-comp-wta-v0336-1127-r.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3051x1716+265+0/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F0f%2Fb0%2Fc4e17dcc4e6b8cc21146046a9da1%2Feah4020-comp-wta-v0336-1127-r.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3051x1716+265+0/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F0f%2Fb0%2Fc4e17dcc4e6b8cc21146046a9da1%2Feah4020-comp-wta-v0336-1127-r.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3051x1716+265+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F0f%2Fb0%2Fc4e17dcc4e6b8cc21146046a9da1%2Feah4020-comp-wta-v0336-1127-r.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3051x1716+265+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F0f%2Fb0%2Fc4e17dcc4e6b8cc21146046a9da1%2Feah4020-comp-wta-v0336-1127-r.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3051x1716+265+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F0f%2Fb0%2Fc4e17dcc4e6b8cc21146046a9da1%2Feah4020-comp-wta-v0336-1127-r.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3051x1716+265+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F0f%2Fb0%2Fc4e17dcc4e6b8cc21146046a9da1%2Feah4020-comp-wta-v0336-1127-r.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3051x1716+265+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F0f%2Fb0%2Fc4e17dcc4e6b8cc21146046a9da1%2Feah4020-comp-wta-v0336-1127-r.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3051x1716+265+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F0f%2Fb0%2Fc4e17dcc4e6b8cc21146046a9da1%2Feah4020-comp-wta-v0336-1127-r.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3051x1716+265+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F0f%2Fb0%2Fc4e17dcc4e6b8cc21146046a9da1%2Feah4020-comp-wta-v0336-1127-r.jpg" class="img" alt="Pedro Pascal as Reed Richards, aka Mister Fantastic." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Pedro Pascal as Reed Richards, aka Mister Fantastic.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          20th Century Studios/Marvel Studios                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;Check out what &lt;/strong&gt;&lt;a href="https://www.npr.org/sections/culture/" target="_blank"&gt;&lt;strong&gt;NPR&lt;/strong&gt;&lt;/a&gt;&lt;strong&gt; is watching, reading and listening to this weekend:&lt;/strong&gt;&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🍿 Movies: &lt;/strong&gt;&lt;a href="https://www.npr.org/2025/07/25/1256217297/the-fantastic-four-first-steps-heralds-good-things-for-the-mcus-future" target="_blank"&gt;&lt;em&gt;The Fantastic Four: First Steps&lt;/em&gt;&lt;/a&gt; is kicking off the Marvel Cinematic Universe's "Phase Six," setting up years of storylines. Here are the other movies &lt;a href="https://www.npr.org/2025/07/24/nx-s1-5475021/fantastic-four-first-steps-oh-hi-diciannove-in-theaters" target="_blank"&gt;hitting theaters this weekend&lt;/a&gt;.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;📺 TV:&lt;/strong&gt; NPR critic Linda Holmes says HBO's two-part documentary &lt;a href="https://www.npr.org/2025/07/24/nx-s1-5472369/hbo-billy-joel-documentary" target="_blank"&gt;&lt;em&gt;Billy Joel: And So It Goes&lt;/em&gt;&lt;/a&gt; highlights Joel's successful career as a result of his strengths in songwriting, piano playing, and live performance.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;📚 Books: &lt;/strong&gt;&lt;a href="https://www.npr.org/2025/07/22/nx-s1-5444029/ww2-family-history-book-together-in-manzanar-tracy-slater" target="_blank"&gt;&lt;em&gt;Together in Manzanar&lt;/em&gt;&lt;/a&gt;&lt;em&gt;: The True Story of a Japanese Jewish Family in an American Concentration Camp &lt;/em&gt;tells the true story of a family of mixed heritage sent to a Japanese detention facility during World War II.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🎵 Music: &lt;/strong&gt;Check out &lt;a href="https://www.npr.org/sections/all-songs-considered/2025/07/25/g-s1-79180/new-music-friday-tyler-childers-patty-griffin" target="_blank"&gt;some of the top albums out today&lt;/a&gt;, with a playlist of some of the best songs released. Don't know where to start? Our &lt;em&gt;All Songs Considered&lt;/em&gt; hosts shared artists similar to the ones featured.&lt;/p&gt;       &lt;p&gt;&lt;strong&gt;🎮 Gaming:&lt;/strong&gt; &lt;a href="https://www.npr.org/2025/07/21/g-s1-78293/shadow-labyrinth-pac-man-twist" target="_blank"&gt;Shadow Labyrinth&lt;/a&gt; is a gritty sci-fi reinterpretation of the Pac-Man character, shedding its trademark yellow colors and world. The game remains kid-friendly.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;❓ Quiz: &lt;/strong&gt;Another week of missing only one question. One of these days, I will get a 100%. Can you do as well as me or better? &lt;a href="https://www.npr.org/2025/07/25/g-s1-79086/trump-tesla-hulk-hogan-ozzy-osborne-coke-doj" target="_blank"&gt;Give it a try&lt;/a&gt;.&lt;/p&gt;   &lt;h3 class="edTag"&gt;3 things to know before you go&lt;/h3&gt;   &lt;div id="resg-s1-79177" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 2000;         --source-height: 1125;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1125+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F93%2F9e%2Fcb56fe6e40adbac0e991ce639884%2Fwhitney-amy-sherald-installation.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1125+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F93%2F9e%2Fcb56fe6e40adbac0e991ce639884%2Fwhitney-amy-sherald-installation.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1125+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F93%2F9e%2Fcb56fe6e40adbac0e991ce639884%2Fwhitney-amy-sherald-installation.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1125+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F93%2F9e%2Fcb56fe6e40adbac0e991ce639884%2Fwhitney-amy-sherald-installation.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1125+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F93%2F9e%2Fcb56fe6e40adbac0e991ce639884%2Fwhitney-amy-sherald-installation.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1125+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F93%2F9e%2Fcb56fe6e40adb