x3780+0+350/resize/600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F87%2F36%2F7bb536c04c7583dc9734498334d0%2Fme-michigan-elections-jpg-070.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6720x3780+0+350/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F87%2F36%2F7bb536c04c7583dc9734498334d0%2Fme-michigan-elections-jpg-070.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6720x3780+0+350/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F87%2F36%2F7bb536c04c7583dc9734498334d0%2Fme-michigan-elections-jpg-070.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6720x3780+0+350/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F87%2F36%2F7bb536c04c7583dc9734498334d0%2Fme-michigan-elections-jpg-070.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6720x3780+0+350/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F87%2F36%2F7bb536c04c7583dc9734498334d0%2Fme-michigan-elections-jpg-070.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6720x3780+0+350/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F87%2F36%2F7bb536c04c7583dc9734498334d0%2Fme-michigan-elections-jpg-070.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6720x3780+0+350/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F87%2F36%2F7bb536c04c7583dc9734498334d0%2Fme-michigan-elections-jpg-070.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6720x3780+0+350/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F87%2F36%2F7bb536c04c7583dc9734498334d0%2Fme-michigan-elections-jpg-070.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/6720x3780+0+350/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F87%2F36%2F7bb536c04c7583dc9734498334d0%2Fme-michigan-elections-jpg-070.jpg" class="img" alt="Carter Chain, a Regional Director for Election integrity for the Trump campaign speaks at an America First Republicans meeting encouraging people to be poll watchers in larger cities in Michigan on Election Day on Oct. 3 in Hillsdale, Mich." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Carter Chain, a Regional Director for Election integrity for the Trump campaign speaks at an America First Republicans meeting encouraging people to be poll watchers in larger cities in Michigan on Election Day on Oct. 3 in Hillsdale, Mich.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Sylvia Jarrus for NPR                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;Americans across the country have begun voting, but many are still convinced that the last presidential election was stolen from them.&lt;/strong&gt; NPR’s Leila Fadel recently visited a small community just outside of Detroit. At a meeting of America First, she asked attendees if they believed this year’s election would be fair. Everyone except three people said no, expressing a lack of trust in the process. Despite their doubts, they all indicated that they would still be voting. The next morning, Fadel visited a civics class where a voting demonstration took place. She spoke with election workers about their feelings of safety going into this election. Here is what they all had to say as &lt;a href="https://one.npr.org/?sharedMediaId=nx-s1-5140572:x"&gt;they voiced their concerns&lt;/a&gt;.&lt;br&gt;&lt;/p&gt;   &lt;h3 class="edTag"&gt;Picture show&lt;/h3&gt;   &lt;div id="resg-s1-6409" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 4000;         --source-height: 2250;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+208/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F6a%2F89%2F1cba9be942d5a20c66780d8498c3%2Faccra-ghana-february-8-2023-muntaka-chasant-for-fondation-carmignac.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+208/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F6a%2F89%2F1cba9be942d5a20c66780d8498c3%2Faccra-ghana-february-8-2023-muntaka-chasant-for-fondation-carmignac.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+208/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F6a%2F89%2F1cba9be942d5a20c66780d8498c3%2Faccra-ghana-february-8-2023-muntaka-chasant-for-fondation-carmignac.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+208/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F6a%2F89%2F1cba9be942d5a20c66780d8498c3%2Faccra-ghana-february-8-2023-muntaka-chasant-for-fondation-carmignac.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+208/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s