2/resize/800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F06%2F65%2F0b7d321f4ec987e66e560d54db62%2Fela-minus-dia-digital-cover-alvaro-ariso.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+152/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F06%2F65%2F0b7d321f4ec987e66e560d54db62%2Fela-minus-dia-digital-cover-alvaro-ariso.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+152/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F06%2F65%2F0b7d321f4ec987e66e560d54db62%2Fela-minus-dia-digital-cover-alvaro-ariso.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+152/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F06%2F65%2F0b7d321f4ec987e66e560d54db62%2Fela-minus-dia-digital-cover-alvaro-ariso.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+152/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F06%2F65%2F0b7d321f4ec987e66e560d54db62%2Fela-minus-dia-digital-cover-alvaro-ariso.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+152/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F06%2F65%2F0b7d321f4ec987e66e560d54db62%2Fela-minus-dia-digital-cover-alvaro-ariso.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+152/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F06%2F65%2F0b7d321f4ec987e66e560d54db62%2Fela-minus-dia-digital-cover-alvaro-ariso.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/3000x1688+0+152/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F06%2F65%2F0b7d321f4ec987e66e560d54db62%2Fela-minus-dia-digital-cover-alvaro-ariso.jpg" class="img" alt="Ela Minus album cover for DÍA" loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Ela Minus album cover for DÍA                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Alvaro Arisó/Pitch Perfect PR                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;Colombian musician Ela Minus is trying to bring a more human touch to the largely electronic music scene, which can often be created without instruments. Minus tells &lt;em&gt;Morning Edition&lt;/em&gt; she was very used to the sound of laptops and wanted to switch it up, so she found hardware synthesizers. A synthesizer is an instrument — separate from a computer — with piano keys. She used the synthesizers and inspiration from dance clubs to make the music on her new album &lt;em&gt;DÍA&lt;/em&gt;. Listen to &lt;a href="https://www.npr.org/2025/01/30/nx-s1-5213901/ela-minus-dia-album-colombia" target="_blank"&gt;snippets of her album&lt;/a&gt; and learn why she chose to go this direction with her sound.&lt;br&gt;&lt;/p&gt;   &lt;h3 class="edTag"&gt;Picture show&lt;/h3&gt;   &lt;div id="resg-s1-46117" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 3772;         --source-height: 2122;     " &gt;         &lt;