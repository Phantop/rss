f0b%2Fpchh-paddington-landscape-wide-b20c4475ee2a8ed275a74461067e25813b8a50f2.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1198x674+1+0/resize/900/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa7%2F6c%2F04f8de2546f2b1b3c0046eb92f0b%2Fpchh-paddington-landscape-wide-b20c4475ee2a8ed275a74461067e25813b8a50f2.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1198x674+1+0/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa7%2F6c%2F04f8de2546f2b1b3c0046eb92f0b%2Fpchh-paddington-landscape-wide-b20c4475ee2a8ed275a74461067e25813b8a50f2.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1198x674+1+0/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa7%2F6c%2F04f8de2546f2b1b3c0046eb92f0b%2Fpchh-paddington-landscape-wide-b20c4475ee2a8ed275a74461067e25813b8a50f2.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1198x674+1+0/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa7%2F6c%2F04f8de2546f2b1b3c0046eb92f0b%2Fpchh-paddington-landscape-wide-b20c4475ee2a8ed275a74461067e25813b8a50f2.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1198x674+1+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa7%2F6c%2F04f8de2546f2b1b3c0046eb92f0b%2Fpchh-paddington-landscape-wide-b20c4475ee2a8ed275a74461067e25813b8a50f2.jpg" sizes="(min-width: 1300px) 763px, (min-width: 1025px) calc(100vw - 496px), (min-width: 768px) calc(100vw - 171px), calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1198x674+1+0/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa7%2F6c%2F04f8de2546f2b1b3c0046eb92f0b%2Fpchh-paddington-landscape-wide-b20c4475ee2a8ed275a74461067e25813b8a50f2.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/1198x674+1+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2Fa7%2F6c%2F04f8de2546f2b1b3c0046eb92f0b%2Fpchh-paddington-landscape-wide-b20c4475ee2a8ed275a74461067e25813b8a50f2.jpg" class="img" alt="Ben Whishaw voices the titular bear in Paddington in Peru." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Ben Whishaw voices the titular bear in &lt;em&gt;Paddington in Peru&lt;/em&gt;.                 &lt;b class="credit" aria-label="Image credit"&gt;                                          &lt;i&gt;Sony Pictures Entertainment Inc.&lt;/i&gt;                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;Check out what &lt;/strong&gt;&lt;a href="https://www.npr.org/sections/culture/" target="_blank"&gt;&lt;strong&gt;NPR&lt;/strong&gt;&lt;/a&gt;&lt;strong&gt; is watching, reading and listening to this weekend:&lt;/strong&gt;&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🍿 Movies: &lt;/strong&gt;In &lt;a href="https://www.npr.org/2025/02/20/1232637577/paddington-in-peru-puts-a-mild-bear-in-the-wild-jungle" target="_blank"&gt;&lt;em&gt;Paddington In Peru&lt;/em&gt;&lt;/a&gt;, Paddington Bear and the Brown family fly across the globe in search of Paddington's Aunt Lucy. Along the way, there is lost treasure, narrow escapes and revelations about Paddington's past.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;📺 TV: &lt;/strong&gt;&lt;em&gt;The Traitors&lt;/em&gt;, a Peacock reality show, features a cast of so-called celebrities who provide a mix of treachery and foolishness. The show is in its third season, and &lt;em&gt;Pop Culture Happy Hour&lt;/em&gt; is &lt;a href="https://one.npr.org/?sharedMediaId=1232304347%2F:1266573446" target="_blank"&gt;fantasy casting who they believe&lt;/a&gt; should be in the next season.&lt;/p&gt;       &lt;p&gt;&lt;strong&gt;📚 Books: &lt;/strong&gt;Eric Puchner's new novel, &lt;a href="https://www.npr.org/2025/02/19/nx-s1-5137197/eric-puchner-dream-state-oprah-pick-male-friendship" target="_blank"&gt;&lt;em&gt;Dream State&lt;/em&gt;&lt;/a&gt;, sounds 'messy' in the best way, so I am adding it to my reading list. It's about a love triangle that tests the decades-long friendship of two college friends and examines different angles of male friendship.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🎵 Music: &lt;/strong&gt;Horsegirl's sophomore album, &lt;a href="https://www.npr.org/2025/02/18/g-s1-49356/horsegirl-phonetics-on-and-on-album-review" target="_blank"&gt;&lt;em&gt;Phonetics On and On&lt;/em&gt;&lt;/a&gt;, keeps things fun with a replayable record full of catchy, bare-bones songwriting and twee treasures.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🍰 Food: &lt;/strong&gt;The &lt;a href="https://www.npr.org/2025/02/20/nx-s1-5299983/first-cookbook-by-black-american-woman-malinda-russell" target="_blank"&gt;first known cookbook&lt;/a&gt; by a Black American woman, &lt;em&gt;A Domestic Cookbook: Containing a Careful Selection of Useful Receipts for the Kitchen&lt;/em&gt;, is out this month with a new edition. The recipes range from old-fashioned desserts to savory options.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;❓ Quiz: &lt;/strong&gt;Beside my quiz score, it said, "Yay! Everyone's a winner." But somehow, it doesn't feel like that when you get three wrong answers. Please &lt;a href="https://www.npr.org/2025/02/21/g-s1-49758/eric-adams-gulf-america-snl-bridget-jones-seal" target="_blank"&gt;top my score&lt;/a&gt; and redeem me.&lt;br&gt;&lt;/p&gt;   &lt;h3 class="edTag"&gt;3 things to know before you go&lt;/h3&gt;   &lt;div id="resg-s1-49691" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 5510;         --source-height: 3099;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5510x3099+0+287/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F22%2Fa4%2F334ca2e54123b0eb2fcb8b2c1fb5%2Fgettyimages-2198948351.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5510x3099+0+287/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F22%2Fa4%2F334ca2e54123b0eb2fcb8b2c1fb5%2Fgettyimages-2198948351.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5510x3099+0+287/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F22%2Fa4%2F334ca2e54123b0eb2fcb8b2c1fb5%2Fgettyimages-2198948351.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5510x3099+0+287/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F22%2Fa4%2F334ca2e54123b0eb2fcb8b2c1fb5%2Fgettyimages-2198948351.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5510x3099+0+287/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F22%2Fa4%2F334ca2e54123b0eb2fcb8b2c1fb5%2Fgettyimages-2198948351.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5510x3099+0+287/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F22%2Fa4%2F334ca2e54123b0eb2fcb8b2c1fb5%2Fgettyimages-2198948351.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/5510x3099+0+287/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F22%2Fa4%2F334ca2e54123b0eb2fcb8b2c1fb5%2Fgettyimages-2198948351.jpg 1800w" data-templa