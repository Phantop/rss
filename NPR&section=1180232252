tp%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F28%2Fd7%2F6b88b48442578896e8f34e68f5b4%2Fdf-07499-r-2000x1333-thumbnail.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+47/resize/1200/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F28%2Fd7%2F6b88b48442578896e8f34e68f5b4%2Fdf-07499-r-2000x1333-thumbnail.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+47/resize/1600/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F28%2Fd7%2F6b88b48442578896e8f34e68f5b4%2Fdf-07499-r-2000x1333-thumbnail.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+47/resize/1800/quality/85/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F28%2Fd7%2F6b88b48442578896e8f34e68f5b4%2Fdf-07499-r-2000x1333-thumbnail.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+47/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F28%2Fd7%2F6b88b48442578896e8f34e68f5b4%2Fdf-07499-r-2000x1333-thumbnail.jpg" sizes="(min-width: 1025px) 650px, calc(100vw - 30px)" class="img" type="image/jpeg" /&gt;             &lt;img src="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+47/resize/1100/quality/50/format/jpeg/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F28%2Fd7%2F6b88b48442578896e8f34e68f5b4%2Fdf-07499-r-2000x1333-thumbnail.jpg" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/2000x1124+0+47/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F28%2Fd7%2F6b88b48442578896e8f34e68f5b4%2Fdf-07499-r-2000x1333-thumbnail.jpg" class="img" alt="Margot Robbie and Colin Farrell in A Big Bold Beautiful Journey." loading="lazy" /&gt;         &lt;/picture&gt; &lt;/div&gt; &lt;div class="credit-caption"&gt;     &lt;div class="caption-wrap"&gt;         &lt;div class="caption" aria-label="Image caption"&gt;             &lt;p&gt;                 Margot Robbie and Colin Farrell in &lt;em&gt;A Big Bold Beautiful Journey.&lt;/em&gt;                 &lt;b class="credit" aria-label="Image credit"&gt;                                          Matt Kennedy/Sony Pictures                                      &lt;/b&gt;                 &lt;b class="hide-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;             &lt;/p&gt;         &lt;/div&gt;               &lt;b class="toggle-caption"&gt;&lt;b&gt;&lt;/b&gt;&lt;/b&gt;     &lt;/div&gt;       &lt;/div&gt;    &lt;/div&gt;    &lt;p&gt;&lt;strong&gt;Check out what &lt;/strong&gt;&lt;a href="https://www.npr.org/sections/culture/" target="_blank"&gt;&lt;strong&gt;NPR&lt;/strong&gt;&lt;/a&gt;&lt;strong&gt; is watching, reading and listening to this weekend:&lt;/strong&gt;&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🍿 Movies:&lt;/strong&gt; &lt;a href="https://www.npr.org/2025/09/23/nx-s1-5550141/a-big-bold-beautiful-journey-review-colin-farrell-margot-robbie-kogonada" target="_blank"&gt;&lt;em&gt;A Big Bold Beautiful Journey&lt;/em&gt;&lt;/a&gt; is a romantic fantasy film starring Colin Farrell and Margot Robbie. In it, they play two strangers traveling in a rental car with a magical GPS that directs them to doors leading them into scenes from the past.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;📺 TV:&lt;/strong&gt; Mark Ruffalo and Tom Pelphrey star in the HBO series &lt;a href="https://www.npr.org/2025/09/24/nx-s1-5551190/in-task-mark-ruffalo-pursues-his-quarry" target="_blank"&gt;&lt;em&gt;Task&lt;/em&gt;&lt;/a&gt;, a gripping crime thriller about an FBI agent who is reluctantly drawn back into the field to investigate a series of drug-related crimes.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;📚 Books:&lt;/strong&gt; In &lt;a href="https://www.npr.org/2025/09/23/nx-s1-5522366/new-books-ian-mcewan-patricia-lockwood-annie-ernaux" target="_blank"&gt;&lt;em&gt;Will There Ever Be Another You&lt;/em&gt;&lt;/a&gt;, the main character struggles with an illness similar to long COVID, descending into a state of debility and psychosis as readers experience the chaos of her unraveling life.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🎵 Music: &lt;/strong&gt;Twenty One Pilots proves rock and roll is alive and well with its album &lt;a href="https://www.npr.org/2025/09/25/g-s1-90445/twenty-one-pilots-breach-no-1-billboard-charts" target="_blank"&gt;&lt;em&gt;Breach&lt;/em&gt;&lt;/a&gt;, landing atop the Billboard 200 chart this week.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🎭 Theater:&lt;/strong&gt; Chess Jakobs' new play, &lt;a href="https://www.npr.org/2025/09/24/nx-s1-5513917/the-american-five-chess-jakobs-ro-boddie" target="_blank"&gt;&lt;em&gt;The American Five&lt;/em&gt;&lt;/a&gt;, explores the story behind how Martin Luther King Jr. and his closest allies organized the March on Washington. NPR speaks with Jakobs and Ro Boddie, who portrays King. &lt;a href="https://one.npr.org/?sharedMediaId=nx-s1-5513917:x" target="_blank"&gt;Listen to their discussion&lt;/a&gt; or &lt;a href="https://www.npr.org/transcripts/nx-s1-5513917" target="_blank"&gt;read the transcript&lt;/a&gt;.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;🎮 Games:&lt;/strong&gt; Good news for Silent Hill fans! The newest edition, &lt;a href="https://www.npr.org/2025/09/22/g-s1-89449/silent-hill-f-review-konami-horror-triumph" target="_blank"&gt;Silent Hill f&lt;/a&gt;, is one of the boldest, darkest, goriest, and outright best games in the entire series, says NPR's Vincent Acovino.&lt;/p&gt;   &lt;p&gt;&lt;strong&gt;❓Quiz:&lt;/strong&gt; Well, this week wasn't my best work. I got four questions wrong, but I know you will do better than I did. &lt;a href="http://npr.org/2025/09/26/g-s1-90432/harris-trump-musk-kimmel-tylenol-baseball-news-quiz" target="_blank"&gt;Give it a try&lt;/a&gt;.&lt;/p&gt;   &lt;h3 class="edTag"&gt;3 things to know before you go&lt;/h3&gt;   &lt;div id="resg-s1-90451" class="bucketwrap image large"&gt;             &lt;div     class="imagewrap has-source-dimensions"     data-crop-type=""     style="         --source-width: 4000;         --source-height: 2250;     " &gt;         &lt;picture&gt;             &lt;source srcset="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+0/resize/400/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F59%2Fa6%2F3551030a4d5bbc93e62edaa53dd4%2Fgettyimages-2226807556.jpg 400w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+0/resize/600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F59%2Fa6%2F3551030a4d5bbc93e62edaa53dd4%2Fgettyimages-2226807556.jpg 600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+0/resize/800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F59%2Fa6%2F3551030a4d5bbc93e62edaa53dd4%2Fgettyimages-2226807556.jpg 800w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+0/resize/900/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F59%2Fa6%2F3551030a4d5bbc93e62edaa53dd4%2Fgettyimages-2226807556.jpg 900w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+0/resize/1200/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F59%2Fa6%2F3551030a4d5bbc93e62edaa53dd4%2Fgettyimages-2226807556.jpg 1200w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+0/resize/1600/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F59%2Fa6%2F3551030a4d5bbc93e62edaa53dd4%2Fgettyimages-2226807556.jpg 1600w, https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+0/resize/1800/quality/85/format/webp/?url=http%3A%2F%2Fnpr-brightspot.s3.amazonaws.com%2F59%2Fa6%2F3551030a4d5bbc93e62edaa53dd4%2Fgettyimages-2226807556.jpg 1800w" data-template="https://npr.brightspotcdn.com/dims3/default/strip/false/crop/4000x2250+0+0/resize/{width}/quality/{quality}/format/{format}/?url=http%3A%2F%2Fnpr-