      <title>Linux Complete by Pearson</title>
      <author>Pearson</author>
      <link>https://humblebundle.com//books/linux-complete-pearson-books</link>
      <guid isPermaLink="false">e45fb171f29ba1218fb730daf6a88f7509a0ddf8</guid>
