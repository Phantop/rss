      <title>The Pentesting &amp; Hacking Toolkit by Packt</title>
      <author>Packt</author>
      <link>https://humblebundle.com//books/pentesting-hacking-toolkit-packt-books</link>
      <guid isPermaLink="false">395307d33612d7c15e18ed18e9896c9c4852a6f3</guid>
