    <item>
      <title>Fiction Music Mod</title>
      <author>AuraDj</author>
      <link>https://gamebanana.com/mods/526644</link>
      <comments>https://gamebanana.com/mods/526644#PostsListModule</comments>
      <guid isPermaLink="false">f5fbcc15677520e463057e12a9b50861e9775101</guid>
      <pubDate>Fri, 23 Aug 2024 09:00:37 +0000</pubDate>
