      <title>The Realm Needs a Prince</title>
      <author> Tegeli </author>
      <link>https://www.scribblehub.com/series/1668514/the-realm-needs-a-prince/</link>
      <comments>https://www.scribblehub.com/read/1668514-the-realm-needs-a-prince/chapter/1750711/#comments</comments>
      <guid isPermaLink="false">15f374daea9636e68f6c5fb19283053d08ee6508</guid>
