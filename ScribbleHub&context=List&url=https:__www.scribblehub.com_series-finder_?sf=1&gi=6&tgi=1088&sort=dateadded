      <title>Project Bloom</title>
      <author> TheCurePumpkin </author>
      <link>https://www.scribblehub.com/series/1796481/project-bloom/</link>
      <comments>https://www.scribblehub.com/read/1796481-project-bloom/chapter/1796835/#comments</comments>
