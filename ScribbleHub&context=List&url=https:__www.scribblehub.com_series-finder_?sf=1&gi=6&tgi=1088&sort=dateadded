      <title>A Life With You</title>
      <author> DrMajalis </author>
      <link>https://www.scribblehub.com/series/1248908/a-life-with-you/</link>
      <comments>https://www.scribblehub.com/read/1248908-a-life-with-you/chapter/1248910/#comments</comments>
      <guid isPermaLink="false">31657fefe64508aa12fc26969dd28a7aee88ac21</guid>
