      <title>Double Double</title>
      <author> Beedok </author>
      <link>https://www.scribblehub.com/series/1358953/double-double/</link>
      <comments>https://www.scribblehub.com/read/1358953-double-double/chapter/1359362/#comments</comments>
      <guid isPermaLink="false">f003ddc7d283e6606b8c5a7b7ed3c9ce096e831c</guid>
