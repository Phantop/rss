      <title>Verdant Blue</title>
      <author> Euphemiss </author>
      <link>https://www.scribblehub.com/series/1721072/verdant-blue/</link>
      <comments>https://www.scribblehub.com/read/1721072-verdant-blue/chapter/1721085/#comments</comments>
      <guid isPermaLink="false">596d09b845041ed228267c2c93d8684c3e2f6ea5</guid>
