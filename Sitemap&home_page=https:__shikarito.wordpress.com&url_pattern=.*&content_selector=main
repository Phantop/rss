ress.com/kusuriya-no-hitorigoto/13-15-the-confession-2/"&gt;15&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/13-16-the-imperial-prince-and-his-wet-nurse/"&gt;16&lt;/a&gt;&lt;/p&gt;    &lt;h3 class="wp-block-heading"&gt;&lt;strong&gt;Arc 14: Smallpox&lt;/strong&gt; (≈LN16)&lt;/h3&gt;    &lt;p class="has-text-align-center"&gt;&lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-01-chicken-meat/"&gt;1&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-02-chitchat/"&gt;2&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-03-the-immortals-abode/"&gt;3&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-04-the-late-shift/"&gt;4&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-05-the-interview/"&gt;5&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-06-dining-hall/"&gt;6&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-07-the-cursed-jar-1/"&gt;7&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-08-the-curse-jar-2/"&gt;8&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-09-the-safflower-1/"&gt;9&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-10-the-safflower-2/"&gt;10&lt;/a&gt; &lt;/p&gt;    &lt;p class="has-text-align-center"&gt;&lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-11-the-safflower-3/"&gt;11&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-12-spell/"&gt;12&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-13-tomato/"&gt;13&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-14-starvation/"&gt;14&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-15-letters/"&gt;15&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-16-girls-night-out/"&gt;16 &lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-17-changsha-peerless/"&gt;17&lt;/a&gt; &lt;/p&gt;    &lt;p class="has-text-align-center"&gt;&lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-18-random-attacker/"&gt;18&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-19-health-check/"&gt;19&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-20-a-new-casualty/"&gt;20&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-21-attenuation/"&gt;21&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-22-the-end-of-quarantine-life/"&gt;22&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-23-the-criminal/"&gt;23&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/14-24-houkou/"&gt;24&lt;/a&gt;&lt;/p&gt;    &lt;h3 class="wp-block-heading"&gt;&lt;strong&gt;Arc 15: Repercussions&lt;/strong&gt; (≈LN17)&lt;/h3&gt;    &lt;p class="has-text-align-center"&gt;&lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/15-01-older-brothers-care/"&gt;1&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/15-02-the-story-of-the-villainess/"&gt;2&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/15-03-peach-blossom-bookstore/"&gt;3&lt;/a&gt; &lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/15-04-a-big-cat/"&gt;4&lt;/a&gt;&lt;/p&gt;    &lt;hr class="wp-block-separator has-alpha-channel-opacity is-style-default" /&gt;    &lt;h3 class="wp-block-heading has-text-align-center"&gt;Side Stories&lt;/h3&gt;    &lt;div class="wp-block-group is-layout-constrained wp-block-group-is-layout-constrained"&gt; &lt;div class="wp-block-group is-vertical is-layout-flex wp-container-core-group-is-layout-fe9cc265 wp-block-group-is-layout-flex"&gt; &lt;p class="has-text-align-center"&gt;Before ARCs 2 and 3 (i.e. Imperial Court 1 + 2) got rewritten to become what it is now, the story ended differently. This is the old version of ARC 2/3, moved to another link for archiving purposes. The side stories here are the sequel to that arc. &lt;a href="https://ncode.syosetu.com/n8967bb/"&gt;Here.&lt;/a&gt;&lt;/p&gt;    &lt;p&gt;&lt;a href="https://creativenovels.com/kusuriya-no-hitorigoto/side-stories-april-first/"&gt;April First&lt;/a&gt;&lt;/p&gt;    &lt;p&gt;&lt;a href="https://creativenovels.com/80/side-story-2-horny-goat-weed/"&gt;Horny Goat Weed&lt;/a&gt;&lt;/p&gt;    &lt;p&gt;&lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/ss-the-villa-1/"&gt;The Villa Part 1&lt;/a&gt;&lt;/p&gt;    &lt;p&gt;&lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/ss-the-villa-2/"&gt;The Villa Part 2&lt;/a&gt;&lt;/p&gt; &lt;/div&gt;    &lt;hr class="wp-block-separator has-alpha-channel-opacity is-style-dots" /&gt;    &lt;p class="has-text-align-center"&gt;And then we have a writing exercise that&amp;#8217;s &lt;em&gt;probably&lt;/em&gt; not canon.&lt;/p&gt;    &lt;p&gt;&lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/ss-untitled/"&gt;Untitled&lt;/a&gt;&lt;/p&gt;    &lt;hr class="wp-block-separator has-alpha-channel-opacity" /&gt;    &lt;p class="has-text-align-center"&gt;This one is technically not WN, but a side story nonetheless. It was released to commemorate the end of the anime&amp;#8217;s 2nd season (to the wider audience at least). Chronologically set near the end of LN4.&lt;/p&gt;    &lt;p&gt;&lt;a href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/ss-sazens-secret/"&gt;Sazen&amp;#8217;s Secret&lt;/a&gt;&lt;/p&gt;    &lt;p&gt;&lt;/p&gt; &lt;/div&gt;    &lt;p&gt;&lt;/p&gt; &lt;div id="jp-post-flair" class="sharedaddy sd-like-enabled"&gt;&lt;div class="sharedaddy sd-sharing-enabled"&gt;&lt;div class="robots-nocontent sd-block sd-social sd-social-official sd-sharing"&gt;&lt;h3 class="sd-title"&gt;Share this:&lt;/h3&gt;&lt;div class="sd-content"&gt;&lt;ul&gt;&lt;li class="share-facebook"&gt;&lt;div class="fb-share-button" data-href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/" data-layout="button_count"&gt;&lt;/div&gt;&lt;/li&gt;&lt;li class="share-end"&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class='sharedaddy sd-block sd-like jetpack-likes-widget-wrapper jetpack-likes-widget-unloaded' id='like-post-wrapper-130534757-17-691898f336c95' data-src='//widgets.wp.com/likes/index.html?ver=20251115#blog_id=130534757&amp;amp;post_id=17&amp;amp;origin=shikarito.wordpress.com&amp;amp;obj_id=130534757-17-691898f336c95' data-name='like-post-frame-130534757-17-691898f336c95' data-title='Like or Reblog'&gt;&lt;div class='likes-widget-placeholder post-likes-widget-placeholder' style='height: 55px;'&gt;&lt;span class='button'&gt;&lt;span&gt;Like&lt;/span&gt;&lt;/span&gt; &lt;span class='loading'&gt;Loading&amp;#8230;&lt;/span&gt;&lt;/div&gt;&lt;span class='sd-text-color'&gt;&lt;/span&gt;&lt;a class='sd-link-color' href="https://shikarito.wordpress.com/kusuriya-no-hitorigoto/"&gt;&lt;/a&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/main&gt;</description>
